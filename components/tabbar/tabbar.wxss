.tabbar {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  bottom: 0;
  height: 124rpx;
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  align-items: center;
  background: rgba(18, 23, 25, 0.98);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 -10rpx 32rpx rgba(0, 0, 0, 0.32);
}

.tab-item {
  flex: 1;
  height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #b7c0c3;
}

.tab-icon {
  height: 58rpx;
  line-height: 58rpx;
  font-size: 52rpx;
  font-weight: 800;
}

.tab-label {
  line-height: 28rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.active {
  color: #f0c15a;
}

.tabbar {
  background: rgba(27, 16, 43, 0.98);
  border-top-color: rgba(216, 180, 254, 0.14);
}

.tab-item {
  color: #c6b8dc;
}

.active {
  color: #d8b4fe;
}
