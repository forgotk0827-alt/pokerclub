.tabbar {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  bottom: 0;
  height: 124rpx;
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  align-items: center;
  background: #242526;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.tab-item {
  flex: 1;
  height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #f0f0f0;
}

.tab-icon {
  height: 58rpx;
  line-height: 58rpx;
  font-size: 52rpx;
  font-weight: 800;
}

.tab-label {
  line-height: 28rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.active {
  color: #ef5b58;
}
