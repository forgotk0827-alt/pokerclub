.activity-page {
  padding-bottom: 150rpx;
}

.date-band {
  height: 168rpx;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  align-items: center;
  background: linear-gradient(90deg, #f03a8c, #ff0068);
}

.date-item {
  height: 144rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 25rpx;
  font-weight: 900;
}

.date-big {
  margin-top: 14rpx;
  font-size: 36rpx;
  line-height: 42rpx;
}

.date-active {
  width: 108rpx;
  height: 108rpx;
  justify-self: center;
  border-radius: 50%;
  background: #fff;
  color: #ff0068;
}

.date-active text:first-child {
  display: none;
}

.chips {
  height: 94rpx;
  padding: 20rpx 22rpx;
  display: flex;
  gap: 20rpx;
  background: #fff;
}

.chip {
  min-width: 112rpx;
  height: 54rpx;
  padding: 0 28rpx;
  border: 2rpx solid #ddd;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f8f8;
  color: #666;
  font-size: 27rpx;
  font-weight: 800;
}

.chip-active {
  border-color: #ff0068;
  background: #ff2c85;
  color: #fff;
}

.activity-tools {
  height: 112rpx;
  padding: 16rpx 22rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  background: #050807;
}

.tool-card {
  height: 80rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  background: #242526;
  color: #fff;
  font-size: 27rpx;
  font-weight: 800;
}

.tool-icon {
  color: #ef5b58;
  font-size: 42rpx;
  line-height: 42rpx;
}

.activity-list {
  height: calc(100vh - 626rpx);
  background: #050807;
}

.activity-card {
  position: relative;
  margin: 22rpx;
  padding: 28rpx 22rpx 84rpx;
  border-radius: 18rpx;
  background: #242526;
  overflow: hidden;
}

.activity-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.activity-title {
  min-width: 0;
  flex: 1;
  color: #fff;
  font-size: 29rpx;
  line-height: 38rpx;
  font-weight: 900;
}

.activity-status {
  color: #aaa;
  font-size: 26rpx;
  font-weight: 800;
}

.activity-body {
  position: relative;
  margin-top: 24rpx;
  display: flex;
  align-items: flex-start;
}

.activity-img {
  flex: 0 0 174rpx;
  width: 174rpx;
  height: 174rpx;
  border-radius: 6rpx;
  background: #161616;
}

.activity-meta {
  min-width: 0;
  flex: 1;
  padding-left: 22rpx;
  padding-right: 118rpx;
}

.meta-line {
  height: 52rpx;
  display: flex;
  align-items: center;
  color: #fff;
  font-size: 28rpx;
  line-height: 34rpx;
  font-weight: 800;
}

.meta-icon {
  flex: 0 0 46rpx;
  width: 46rpx;
  height: 40rpx;
  margin-right: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f4f5f6;
  color: #242526;
  font-size: 27rpx;
}

.activity-price {
  position: absolute;
  right: 0;
  top: 5rpx;
  color: #ff1717;
  font-size: 28rpx;
  font-weight: 500;
}

.join-row {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.avatars {
  display: flex;
  gap: 12rpx;
}

.avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #6788aa;
  color: #e8e8e8;
  font-size: 20rpx;
}

.quota {
  color: #fff;
  font-size: 30rpx;
}

.quota text {
  color: #ff1717;
  font-weight: 900;
}

.ended-mark {
  position: absolute;
  left: 260rpx;
  top: 148rpx;
  width: 260rpx;
  height: 64rpx;
  transform: rotate(-45deg);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.58);
  color: #fff;
  font-size: 36rpx;
  font-weight: 900;
}

.join-btn {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  bottom: 18rpx;
  height: 54rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ef5b58;
  color: #fff;
  font-weight: 900;
}

.join-disabled {
  background: #555;
  color: #bdbdbd;
}

.empty {
  padding-top: 160rpx;
  color: #fff;
  text-align: center;
  font-size: 30rpx;
  font-weight: 800;
}

.modal-mask {
  position: fixed;
  z-index: 30;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.58);
}

.signup-panel {
  width: 100%;
  padding: 34rpx 30rpx 50rpx;
  border-radius: 24rpx 24rpx 0 0;
  background: #242526;
}

.panel-title {
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.panel-desc {
  margin-top: 16rpx;
  color: #b5b5b5;
  font-size: 26rpx;
  line-height: 36rpx;
}

.panel-row {
  min-height: 64rpx;
  padding: 18rpx 0;
  display: grid;
  grid-template-columns: 160rpx 1fr;
  gap: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
  color: #fff;
  font-size: 27rpx;
  line-height: 36rpx;
}

.panel-row text:first-child {
  color: #aaa;
}

.panel-actions {
  margin-top: 30rpx;
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 20rpx;
}
