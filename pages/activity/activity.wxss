.activity-page {
  padding-bottom: 150rpx;
}

.store-switch {
  margin: 20rpx 20rpx 16rpx;
  padding: 22rpx 20rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  color: #111827;
}

.store-switch-main {
  min-width: 0;
  flex: 1;
}

.store-switch-label {
  color: #6b7280;
  font-size: 22rpx;
  line-height: 30rpx;
}

.store-switch-name {
  margin-top: 6rpx;
  color: #111827;
  font-size: 30rpx;
  line-height: 38rpx;
  font-weight: 900;
}

.store-switch-arrow {
  flex: 0 0 32rpx;
  color: #9ca3af;
  font-size: 56rpx;
  line-height: 1;
}

.date-band {
  height: 168rpx;
  display: flex;
  align-items: center;
  background: linear-gradient(90deg, #f03a8c, #ff0068);
}

.date-item {
  flex: 1;
  min-width: 0;
  height: 144rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.date-pill {
  width: 118rpx;
  height: 122rpx;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  line-height: 22rpx;
  font-weight: 900;
  text-align: center;
}

.date-pill-all {
  width: 96rpx;
  height: 96rpx;
}

.date-text {
  display: block;
  width: 100%;
  overflow: hidden;
  white-space: nowrap;
  text-align: center;
}

.date-weekday {
  display: block;
  width: 100%;
  margin-top: 2rpx;
  overflow: hidden;
  white-space: nowrap;
  text-align: center;
}

.date-big {
  margin-top: 6rpx;
  font-size: 30rpx;
  line-height: 34rpx;
}

.date-active {
  border-radius: 62rpx;
  background: #fff;
  color: #ff0068;
}

.chips {
  height: 94rpx;
  padding: 20rpx 22rpx;
  display: flex;
  gap: 20rpx;
  background: #fff;
}

.chip {
  min-width: 112rpx;
  height: 54rpx;
  padding: 0 28rpx;
  border: 2rpx solid #ddd;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f8f8;
  color: #666;
  font-size: 27rpx;
  font-weight: 800;
}

.chip-active {
  border-color: #ff0068;
  background: #ff2c85;
  color: #fff;
}

.activity-list {
  height: calc(100vh - 628rpx);
  background: #050807;
}

.activity-card {
  position: relative;
  margin: 22rpx;
  padding: 28rpx 22rpx 28rpx;
  border-radius: 18rpx;
  background: #242526;
  overflow: hidden;
}

.activity-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.activity-title {
  min-width: 0;
  flex: 1;
  color: #fff;
  font-size: 29rpx;
  line-height: 38rpx;
  font-weight: 900;
}

.activity-status {
  color: #aaa;
  font-size: 26rpx;
  font-weight: 800;
}

.activity-body {
  position: relative;
  margin-top: 24rpx;
  display: flex;
  align-items: flex-start;
}

.activity-img {
  flex: 0 0 174rpx;
  width: 174rpx;
  height: 174rpx;
  border-radius: 6rpx;
  background: #161616;
}

.activity-meta {
  min-width: 0;
  flex: 1;
  padding-left: 22rpx;
  padding-right: 118rpx;
}

.meta-line {
  height: 52rpx;
  display: flex;
  align-items: center;
  color: #fff;
  font-size: 28rpx;
  line-height: 34rpx;
  font-weight: 800;
}

.meta-icon {
  flex: 0 0 46rpx;
  width: 46rpx;
  height: 40rpx;
  margin-right: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f4f5f6;
  color: #242526;
  font-size: 27rpx;
}

.activity-price {
  position: absolute;
  right: 0;
  top: 5rpx;
  color: #ff1717;
  font-size: 28rpx;
  font-weight: 500;
}

.join-row {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.avatars {
  display: flex;
  align-items: center;
  max-width: 430rpx;
}

.avatar {
  width: 48rpx;
  height: 48rpx;
  margin-right: -8rpx;
  border: 2rpx solid rgba(43, 18, 63, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #6788aa;
  color: #e8e8e8;
  font-size: 20rpx;
  box-sizing: border-box;
}

.quota {
  color: #fff;
  font-size: 30rpx;
}

.quota text {
  color: #ff1717;
  font-weight: 900;
}

.ended-mark {
  position: absolute;
  left: 260rpx;
  top: 148rpx;
  width: 260rpx;
  height: 64rpx;
  transform: rotate(-45deg);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.58);
  color: #fff;
  font-size: 36rpx;
  font-weight: 900;
}

.empty {
  padding-top: 160rpx;
  color: #fff;
  text-align: center;
  font-size: 30rpx;
  font-weight: 800;
}

.modal-mask {
  position: fixed;
  z-index: 30;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.58);
}

.signup-panel {
  width: 100%;
  padding: 34rpx 30rpx 50rpx;
  border-radius: 24rpx 24rpx 0 0;
  background: #242526;
}

.panel-title {
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.panel-desc {
  margin-top: 16rpx;
  color: #b5b5b5;
  font-size: 26rpx;
  line-height: 36rpx;
}

.panel-row {
  min-height: 64rpx;
  padding: 18rpx 0;
  display: grid;
  grid-template-columns: 160rpx 1fr;
  gap: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
  color: #fff;
  font-size: 27rpx;
  line-height: 36rpx;
}

.panel-row text:first-child {
  color: #aaa;
}

.panel-actions {
  margin-top: 30rpx;
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 20rpx;
}

.activity-page,
.activity-list {
  background: #0b0f10;
}

.date-band {
  background: linear-gradient(90deg, #1d3838, #d74f45);
}

.date-active {
  background: #f8f3e7;
  color: #1d3838;
}

.chips {
  background: #111719;
}

.chip {
  border-color: rgba(255, 255, 255, 0.1);
  background: #1b2022;
  color: #b7c0c3;
}

.chip-active {
  border-color: rgba(240, 193, 90, 0.55);
  background: #f0c15a;
  color: #17191c;
}

.activity-card {
  border-radius: 8rpx;
  background: #1b2022;
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.24);
}

.activity-img {
  border-radius: 8rpx;
  background: #101415;
}

.activity-status,
.activity-price,
.quota text {
  color: #f0c15a;
}

.meta-icon {
  border-radius: 8rpx;
  background: #f8f3e7;
  color: #1b2022;
}

.signup-panel {
  background: #1b2022;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.activity-page,
.activity-list {
  background: #120a1f;
}

.date-band {
  background: linear-gradient(90deg, #3b1b5f, #8b5cf6);
}

.date-active {
  background: #efe7ff;
  color: #4c1d95;
}

.chips {
  background: #1b102b;
}

.chip {
  border-color: rgba(216, 180, 254, 0.14);
  background: #241633;
  color: #c6b8dc;
}

.chip-active {
  border-color: rgba(216, 180, 254, 0.6);
  background: #8b5cf6;
  color: #fff;
}

.activity-card,
.signup-panel {
  background: #241633;
  border-color: rgba(216, 180, 254, 0.13);
  box-shadow: 0 14rpx 34rpx rgba(24, 11, 39, 0.32);
}

.activity-img {
  background: #180f27;
}

.activity-status,
.activity-price,
.quota text {
  color: #d8b4fe;
}

.meta-icon {
  background: #efe7ff;
  color: #4c1d95;
}
