<topbar title="活动报名" />
<view class="page activity-page">
  <view class="store-switch" bindtap="switchStore">
    <view class="store-switch-main">
      <view class="store-switch-label">当前门店</view>
      <view class="store-switch-name">{{selectedStoreName || '请选择门店'}}</view>
    </view>
    <view class="store-switch-arrow">›</view>
  </view>

  <view class="date-band">
    <view wx:for="{{dates}}" wx:key="key" class="date-item" data-key="{{item.key}}" bindtap="selectDay">
      <view class="date-pill {{activeDay === item.key ? 'date-active' : ''}} {{item.key === 'all' ? 'date-pill-all' : ''}}">
        <text wx:if="{{item.date}}" class="date-text">{{item.date}}</text>
        <text wx:if="{{item.weekday}}" class="date-weekday">{{item.weekday}}</text>
        <text class="date-big">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="chips">
    <button wx:for="{{types}}" wx:key="name" class="chip {{activeType === item.name ? 'chip-active' : ''}}" data-name="{{item.name}}" bindtap="selectType">{{item.name}}</button>
  </view>

  <scroll-view scroll-y class="activity-list">
    <view class="activity-card" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="openDetail">
      <view class="activity-head">
        <view class="activity-title">{{item.title}}</view>
        <view class="activity-status">{{item.statusText}}</view>
      </view>
      <view class="activity-body">
        <image wx:if="{{item.image}}" class="activity-img" src="{{item.image}}" mode="aspectFill" />
        <view class="activity-meta">
          <view class="meta-line"><text class="meta-icon">◷</text><text>{{item.date}}</text></view>
          <view class="meta-line"><text class="meta-icon">⌖</text><text class="line-clamp">{{item.location}}</text></view>
          <view class="meta-line muted"><text class="meta-icon">◷</text><text>{{item.deadlineAt || item.deadline}}</text></view>
        </view>
        <view class="activity-price">¥{{item.price}}.00</view>
      </view>
      <view class="join-row">
        <view class="avatars">
          <block wx:for="{{item.avatars}}" wx:key="id">
            <image wx:if="{{item.avatarUrl}}" class="avatar avatar-img" src="{{item.avatarUrl}}" mode="aspectFill" />
            <view wx:else class="avatar">{{item.avatarText}}</view>
          </block>
        </view>
        <view class="quota"><text>{{item.joined}}</text>/{{item.quota}}</view>
      </view>
      <view wx:if="{{item.signupClosed}}" class="ended-mark">已截止</view>
    </view>
    <view wx:if="{{!list.length}}" class="empty">暂无活动</view>
  </scroll-view>
</view>
<main-tabbar active="activity" />
