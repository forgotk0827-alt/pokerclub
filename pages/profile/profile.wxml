<topbar title="我的信息" />
<scroll-view scroll-y class="page profile-page">
  <view class="profile-hero">
    <image wx:if="{{member.avatarUrl}}" class="avatar avatar-img" src="{{member.avatarUrl}}" mode="aspectFill" />
    <view wx:else class="avatar">{{member.avatarText}}</view>
    <view class="profile-main">
      <view class="nickname">{{member.nickname}}</view>
      <view class="badge">{{member.level}}</view>
      <button wx:if="{{!isLoggedIn}}" class="login-btn" bindtap="oneTapLogin">微信一键登录</button>
      <button wx:else class="edit-name-btn" bindtap="openProfileEditor">修改昵称和头像</button>
    </view>
    <view class="qr-box" bindtap="showMemberQr">
      <view class="real-qr small-qr">
        <view wx:for="{{memberQr}}" wx:for-item="row" wx:for-index="rowIndex" wx:key="rowIndex" class="qr-row">
          <view wx:for="{{row}}" wx:for-item="cell" wx:for-index="cellIndex" wx:key="cellIndex" class="qr-cell {{cell ? 'qr-dark' : ''}}"></view>
        </view>
      </view>
      <text class="qr-label">会员二维码</text>
    </view>
  </view>

  <view class="balance-card" bindtap="goRecharge">
    <view class="balance-top">
      <view class="balance-label">储值卡余额</view>
      <view class="balance-link">去充值</view>
    </view>
    <view class="balance-num">{{member.balance}}</view>
    <view class="balance-tip">点餐时可优先抵扣储值余额与酒水券</view>
  </view>

  <view class="stats">
    <view class="stat" bindtap="goPoints">
      <text class="stat-num">{{member.points}}</text>
      <text class="stat-label">我的积分</text>
    </view>
    <view class="split"></view>
    <view class="stat" bindtap="goFragments">
      <text class="stat-num">{{member.gems || member.invitePieces || 0}}</text>
      <text class="stat-label">我的碎片</text>
    </view>
    <view class="split"></view>
    <view class="stat" bindtap="goVoucher">
      <text class="stat-num">{{member.drinkVoucherCount || 0}}</text>
      <text class="stat-label">我的酒水券</text>
    </view>
  </view>

  <view class="menu-panel">
    <view class="menu-title">我的</view>
    <view class="menu-line"></view>
    <view class="menu-grid">
      <view class="menu-item" bindtap="goSignups">
        <view class="menu-symbol signup-symbol"></view>
        <text>我的报名</text>
      </view>
      <view class="menu-item" bindtap="goPoints">
        <view class="menu-symbol points-symbol"></view>
        <text>我的积分</text>
      </view>
      <view class="menu-item" bindtap="goOrders">
        <view class="menu-symbol order-symbol"></view>
        <text>我的订单</text>
      </view>
      <view class="menu-item" bindtap="goFavorites">
        <view class="menu-symbol flag-symbol"></view>
        <text>我的收藏</text>
      </view>
      <view class="menu-item" bindtap="goCellar">
        <view class="menu-symbol cellar-symbol"></view>
        <text>我的存酒</text>
      </view>
      <view class="menu-item" bindtap="goMerchant">
        <view class="menu-symbol merchant-symbol"></view>
        <text>商家端</text>
      </view>
      <view class="menu-item" bindtap="goInfo">
        <view class="menu-symbol profile-symbol"></view>
        <text>个人资料</text>
      </view>
      <view class="menu-item" bindtap="goFaq">
        <view class="menu-symbol faq-symbol">?</view>
        <text>常见问题</text>
      </view>
      <view class="menu-item" bindtap="goJoinUs">
        <view class="menu-symbol about-symbol"></view>
        <text>加入我们</text>
      </view>
      <view class="menu-item logout-item" bindtap="logout">
        <view class="menu-symbol logout-symbol"></view>
        <text>退出登录</text>
      </view>
    </view>
  </view>

  <view wx:if="{{globalSettings.groupQrImage}}" class="group-qr-section">
    <image class="group-qr-code" src="{{globalSettings.groupQrImage}}" mode="aspectFit" bindtap="previewGroupQr" />
    <view class="group-qr-tip">{{globalSettings.groupQrTip || '点击打开二维码后长按识别加入店铺群'}}</view>
  </view>

  <view wx:if="{{qrVisible}}" class="member-qr-mask" bindtap="closeMemberQr">
    <view class="member-qr-dialog" catchtap="noop">
      <view class="member-qr-head">
        <text>{{qrTime}}</text>
        <view class="member-qr-close" bindtap="closeMemberQr">×</view>
      </view>
      <view class="member-qr-body">
        <view class="member-qr-title">会员二维码</view>
        <view class="real-qr member-qr-large">
          <view wx:for="{{memberQr}}" wx:for-item="row" wx:for-index="rowIndex" wx:key="rowIndex" class="qr-row">
            <view wx:for="{{row}}" wx:for-item="cell" wx:for-index="cellIndex" wx:key="cellIndex" class="qr-cell {{cell ? 'qr-dark' : ''}}"></view>
          </view>
        </view>
        <view class="member-qr-tip">出示二维码给店员扫码</view>
      </view>
    </view>
  </view>

  <view wx:if="{{profileEditorVisible}}" class="profile-editor-mask" bindtap="closeProfileEditor">
    <view class="profile-editor-dialog" catchtap="noop">
      <view class="profile-editor-head">
        <view class="profile-editor-title">{{profileEditorMode === 'login' ? '完善会员资料' : '修改昵称和头像'}}</view>
        <view class="profile-editor-subtitle">
          {{profileEditorMode === 'login' ? '先选择头像和昵称，再完成手机号授权' : '编辑后会同步到后端和我的信息页'}}
        </view>
      </view>
      <view class="profile-avatar-block">
        <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="chooseProfileAvatar">
          <image wx:if="{{profileForm.avatarUrl}}" class="editor-avatar-img" src="{{profileForm.avatarUrl}}" mode="aspectFill" />
          <view wx:else class="editor-avatar-placeholder">
            <view class="editor-avatar-plus">+</view>
            <text>头像</text>
          </view>
        </button>
        <view class="avatar-hint">点击更换头像</view>
      </view>
      <view class="profile-field-card" bindtap="showNicknameTip">
        <view class="profile-field">
          <view class="profile-field-label">昵称</view>
          <input class="profile-nickname-input" type="nickname" value="{{profileForm.nickname}}" placeholder="请输入昵称" bindinput="inputProfileNickname" bindfocus="showNicknameTip" />
        </view>
      </view>
      <view wx:if="{{profileEditorMode === 'login'}}" class="privacy-accept">
        <checkbox-group bindchange="togglePrivacyAgreement">
          <label class="privacy-label">
            <checkbox value="agree" checked="{{privacyAgreed}}" color="#8b5cf6" />
            <text>我已阅读并同意</text>
            <text class="privacy-link" bindtap="openPrivacyPolicy">《隐私协议》</text>
          </label>
        </checkbox-group>
      </view>
      <view wx:if="{{nicknameTipVisible}}" class="profile-tip-overlay">建议使用微信昵称，方便门店识别和核对</view>
      <view class="profile-editor-actions">
        <view class="profile-cancel" bindtap="closeProfileEditor">取消</view>
        <button wx:if="{{profileEditorMode === 'login'}}" class="profile-save" open-type="getPhoneNumber" bindgetphonenumber="confirmProfileLogin" disabled="{{!privacyAgreed}}">继续登录</button>
        <view wx:else class="profile-save" bindtap="saveProfileEditor">保存资料</view>
      </view>
    </view>
  </view>
</scroll-view>
<main-tabbar active="profile" />
