.profile-page {
  padding: 0 28rpx 170rpx;
  background: #242526;
}

.profile-hero {
  min-height: 200rpx;
  padding: 58rpx 0 28rpx;
  display: grid;
  grid-template-columns: 136rpx minmax(0, 1fr) 116rpx;
  gap: 22rpx;
  align-items: center;
}

.avatar {
  width: 136rpx;
  height: 136rpx;
  border: 4rpx solid #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #9dadde;
  color: #fff;
  font-size: 72rpx;
  font-weight: 400;
}

.profile-main {
  min-width: 0;
}

.nickname {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #fff;
  font-size: 42rpx;
  line-height: 52rpx;
  font-weight: 500;
}

.badge {
  width: 108rpx;
  height: 34rpx;
  margin-top: 12rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffb100;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
}

.login-btn,
.edit-name-btn {
  margin-top: 12rpx;
  min-width: 186rpx;
  height: 46rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #e25754;
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
}

.edit-name-btn {
  min-width: 112rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.qr-box {
  text-align: center;
}

.qr-code {
  position: relative;
  margin: 0 auto;
  background:
    linear-gradient(90deg, #111 10%, transparent 10%, transparent 20%, #111 20%, #111 30%, transparent 30%, transparent 40%, #111 40%, #111 50%, transparent 50%, transparent 60%, #111 60%, #111 70%, transparent 70%, transparent 80%, #111 80%),
    linear-gradient(#111 10%, transparent 10%, transparent 20%, #111 20%, #111 30%, transparent 30%, transparent 40%, #111 40%, #111 50%, transparent 50%, transparent 60%, #111 60%, #111 70%, transparent 70%, transparent 80%, #111 80%),
    #fff;
  background-size: 100% 100%;
}

.small-qr {
  width: 76rpx;
  height: 76rpx;
  border: 5rpx solid #fff;
  border-radius: 6rpx;
}

.real-qr {
  display: flex;
  flex-direction: column;
  padding: 8rpx;
  background: #fff;
}

.qr-row {
  flex: 1;
  display: flex;
}

.qr-cell {
  flex: 1;
  background: #fff;
}

.qr-dark {
  background: #000;
}

.qr-label {
  display: block;
  margin-top: 8rpx;
  color: #ffcf00;
  font-size: 20rpx;
}

.balance-card {
  margin-top: 12rpx;
  padding: 22rpx 24rpx 20rpx;
  border-radius: 16rpx;
  background: linear-gradient(100deg, #5b21b6, #8b5cf6);
  color: #fff;
}

.balance-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.balance-label {
  font-size: 26rpx;
  font-weight: 800;
}

.balance-link {
  color: #f5d0fe;
  font-size: 24rpx;
  font-weight: 700;
}

.balance-num {
  margin-top: 10rpx;
  font-size: 48rpx;
  line-height: 54rpx;
  font-weight: 900;
}

.balance-tip {
  margin-top: 8rpx;
  color: #f3e8ff;
  font-size: 22rpx;
}

.stats {
  height: 122rpx;
  margin-top: 20rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: stretch;
  overflow: hidden;
  background: #fff;
  color: #242526;
}

.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.split {
  width: 1rpx;
  margin: 0;
  background: #ececec;
}

.stat-num {
  color: #1f2937;
  font-size: 38rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.stat-label {
  margin-top: 8rpx;
  color: #999;
  font-size: 24rpx;
}

.menu-panel {
  margin-top: 48rpx;
  padding: 22rpx 22rpx 28rpx;
  border-radius: 8rpx;
  background: #fff;
  color: #111;
}

.menu-title {
  padding: 0 10rpx 18rpx;
  font-size: 32rpx;
  line-height: 42rpx;
  font-weight: 500;
}

.menu-line {
  height: 1rpx;
  background: #ececec;
}

.menu-grid {
  padding-top: 26rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  row-gap: 34rpx;
}

.menu-item {
  width: 100%;
  min-width: 0;
  min-height: 112rpx;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #111;
  font-size: 24rpx;
  line-height: 32rpx;
  text-align: center;
}

.menu-item text {
  display: block;
  width: 100%;
  overflow: visible;
  white-space: nowrap;
  text-align: center;
}

.group-qr-section {
  margin: 72rpx 0 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.group-qr-code {
  width: 250rpx;
  height: 250rpx;
  display: block;
  background: #fff;
}

.group-qr-tip {
  margin-top: 24rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 26rpx;
  line-height: 36rpx;
}

.group-qr-support {
  margin-top: 42rpx;
  color: rgba(255, 255, 255, 0.46);
  font-size: 24rpx;
  line-height: 34rpx;
}

.service-qr-section {
  margin: 56rpx 0 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.service-qr-code {
  width: 360rpx;
  height: 360rpx;
  display: block;
  border-radius: 8rpx;
  background: #fff;
}

.service-qr-tip {
  margin-top: 22rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 28rpx;
  line-height: 38rpx;
  font-weight: 700;
}

.menu-symbol {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  color: #333;
}

.signup-symbol::before {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 4rpx;
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #333;
  border-radius: 50%;
}

.signup-symbol::after {
  content: "";
  position: absolute;
  right: 4rpx;
  bottom: 2rpx;
  width: 24rpx;
  height: 30rpx;
  border: 4rpx solid #333;
  border-radius: 6rpx;
}

.points-symbol {
  border: 4rpx solid #333;
  border-radius: 50%;
  box-shadow: 0 12rpx 0 -5rpx #fff, 0 14rpx 0 -3rpx #333, 0 26rpx 0 -5rpx #fff, 0 28rpx 0 -3rpx #333;
}

.order-symbol {
  border: 4rpx solid #333;
  border-radius: 6rpx;
}

.order-symbol::before,
.order-symbol::after {
  content: "";
  position: absolute;
  left: 13rpx;
  right: 13rpx;
  height: 4rpx;
  background: #333;
}

.order-symbol::before {
  top: 16rpx;
}

.order-symbol::after {
  top: 28rpx;
}

.flag-symbol {
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  border-radius: 0 0 0 24rpx;
}

.flag-symbol::before {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 2rpx;
  width: 34rpx;
  height: 24rpx;
  border: 4rpx solid #333;
  border-left: 0;
  border-radius: 0 22rpx 22rpx 0;
}

.profile-symbol {
  border: 4rpx solid #333;
  border-radius: 6rpx;
}

.profile-symbol::before {
  content: "";
  position: absolute;
  left: 9rpx;
  top: 11rpx;
  width: 12rpx;
  height: 12rpx;
  border: 3rpx solid #333;
  border-radius: 50%;
}

.profile-symbol::after {
  content: "";
  position: absolute;
  right: 8rpx;
  top: 16rpx;
  width: 16rpx;
  height: 4rpx;
  background: #333;
  box-shadow: 0 12rpx 0 #333;
}

.faq-symbol {
  border-radius: 50%;
  background: #111;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 900;
}

.about-symbol {
  border-radius: 50%;
  background: #333;
}

.about-symbol::after {
  content: "";
  position: absolute;
  left: 17rpx;
  bottom: -10rpx;
  border-left: 9rpx solid transparent;
  border-right: 9rpx solid transparent;
  border-top: 16rpx solid #333;
}

.logout-item {
  color: #c62828;
}

.logout-symbol {
  border: 4rpx solid #c62828;
  border-radius: 50%;
}

.logout-symbol::before {
  content: "";
  position: absolute;
  left: 12rpx;
  top: 10rpx;
  width: 14rpx;
  height: 14rpx;
  border-top: 4rpx solid #c62828;
  border-right: 4rpx solid #c62828;
  transform: rotate(45deg);
}

.logout-symbol::after {
  content: "";
  position: absolute;
  left: 21rpx;
  top: 18rpx;
  width: 18rpx;
  height: 4rpx;
  background: #c62828;
}

.cellar-symbol {
  border: 4rpx solid #333;
  border-radius: 4rpx 4rpx 16rpx 16rpx;
}

.cellar-symbol::before {
  content: "";
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  top: -12rpx;
  height: 14rpx;
  border: 4rpx solid #333;
  border-bottom: 0;
  border-radius: 10rpx 10rpx 0 0;
}

.cellar-symbol::after {
  content: "";
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  top: 19rpx;
  height: 4rpx;
  background: #333;
  box-shadow: 0 12rpx 0 #333;
}

.video-symbol {
  border: 4rpx solid #333;
  border-radius: 8rpx;
}

.video-symbol::after {
  content: "";
  position: absolute;
  left: 19rpx;
  top: 13rpx;
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 16rpx solid #333;
}

.rank-symbol {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 5rpx;
}

.rank-symbol::before,
.rank-symbol::after {
  content: "";
  display: block;
  width: 12rpx;
  background: #333;
  border-radius: 4rpx 4rpx 0 0;
}

.rank-symbol::before {
  height: 26rpx;
}

.rank-symbol::after {
  height: 42rpx;
  box-shadow: 18rpx 12rpx 0 #333;
}

.merchant-symbol {
  border: 4rpx solid #333;
  border-radius: 6rpx 6rpx 14rpx 14rpx;
}

.merchant-symbol::before {
  content: "";
  position: absolute;
  left: -4rpx;
  right: -4rpx;
  top: -14rpx;
  height: 16rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: #333;
}

.merchant-symbol::after {
  content: "";
  position: absolute;
  left: 12rpx;
  bottom: 0;
  width: 16rpx;
  height: 22rpx;
  border: 4rpx solid #333;
  border-bottom: 0;
}

.member-qr-mask {
  position: fixed;
  z-index: 40;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.68);
}

.member-qr-dialog {
  width: 508rpx;
  overflow: hidden;
  border-radius: 14rpx;
  background: #fff;
}

.member-qr-head {
  height: 100rpx;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(90deg, #6e7fe8, #7a55b5);
  color: #fff;
  font-size: 25rpx;
  font-weight: 900;
}

.member-qr-close {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 52rpx;
  line-height: 50rpx;
  font-weight: 300;
}

.member-qr-body {
  padding: 34rpx 0 34rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.member-qr-title {
  color: #333;
  font-size: 30rpx;
  line-height: 40rpx;
  font-weight: 900;
}

.member-qr-large {
  width: 318rpx;
  height: 318rpx;
  margin: 26rpx auto 0;
  border: 1rpx solid #eee;
  border-radius: 6rpx;
}

.member-qr-tip {
  margin-top: 24rpx;
  color: #9a9a9a;
  font-size: 24rpx;
}

.profile-page {
  background:
    linear-gradient(180deg, #172325 0%, #0b0f10 390rpx),
    #0b0f10;
}

.avatar {
  border-color: rgba(240, 193, 90, 0.8);
  background: linear-gradient(135deg, #3d5457, #61b3aa);
  box-shadow: 0 14rpx 32rpx rgba(0, 0, 0, 0.28);
}

.nickname {
  color: #f7f0df;
  font-weight: 800;
}

.badge {
  background: #f0c15a;
  color: #17191c;
}

.login-btn {
  background: #d74f45;
}

.vip-banner {
  border-radius: 8rpx;
  background: linear-gradient(100deg, #1d3838, #d74f45);
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.24);
}

.stats,
.menu-panel {
  border-radius: 8rpx;
  background: #f8f3e7;
  color: #202426;
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.22);
}

.stat-num {
  color: #1d3838;
}

.profile-page {
  background:
    linear-gradient(180deg, #2d1b46 0%, #120a1f 390rpx),
    #120a1f;
}

.avatar {
  border-color: rgba(216, 180, 254, 0.82);
  background: linear-gradient(135deg, #5b21b6, #a78bfa);
}

.nickname {
  color: #f4ecff;
}

.badge {
  background: #d8b4fe;
  color: #32124f;
}

.login-btn {
  background: #8b5cf6;
}

.vip-banner {
  background: linear-gradient(100deg, #3b1b5f, #8b5cf6);
}

.stats,
.menu-panel {
  background: #efe7ff;
  color: #241633;
}

.stat-num {
  color: #6d28d9;
}

.profile-editor-mask {
  position: fixed;
  inset: 0;
  z-index: 60;
  padding: 36rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(11, 15, 16, 0.66);
  box-sizing: border-box;
}

.profile-editor-dialog {
  position: relative;
  width: 100%;
  max-width: 640rpx;
  padding: 34rpx 28rpx 28rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8f7ff 100%);
  box-shadow: 0 24rpx 64rpx rgba(17, 24, 39, 0.22);
  box-sizing: border-box;
}

.profile-editor-head {
  text-align: center;
}

.profile-editor-title {
  color: #111827;
  font-size: 34rpx;
  line-height: 46rpx;
  text-align: center;
  font-weight: 900;
}

.profile-editor-subtitle {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 32rpx;
}

.profile-avatar-block {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-picker {
  width: 132rpx;
  height: 132rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ede9fe, #ddd6fe);
  box-shadow: 0 12rpx 28rpx rgba(139, 92, 246, 0.16);
  overflow: hidden;
}

.avatar-picker::after {
  border: 0;
}

.editor-avatar-img,
.editor-avatar-placeholder {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
}

.editor-avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #f5f3ff, #e9d5ff);
  color: #8b5cf6;
  font-size: 22rpx;
  font-weight: 800;
}

.editor-avatar-plus {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(139, 92, 246, 0.12);
  color: #8b5cf6;
  font-size: 34rpx;
  line-height: 34rpx;
  font-weight: 900;
}

.avatar-hint {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 32rpx;
}

.profile-field-card {
  margin-top: 24rpx;
  padding: 8rpx 18rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: inset 0 0 0 1rpx rgba(139, 92, 246, 0.08);
}

.profile-field {
  min-height: 92rpx;
  display: grid;
  grid-template-columns: 140rpx minmax(0, 1fr);
  align-items: center;
}

.profile-field-label {
  color: #111827;
  font-size: 26rpx;
  font-weight: 800;
}

.profile-nickname-input {
  height: 92rpx;
  color: #111827;
  font-size: 28rpx;
}

.privacy-accept {
  margin-top: 18rpx;
  padding: 18rpx 18rpx 4rpx;
  border-radius: 16rpx;
  background: #fff;
}

.privacy-label {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 32rpx;
}

.privacy-link {
  color: #8b5cf6;
  font-weight: 800;
}

.profile-editor-actions {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  align-items: stretch;
}

.profile-cancel,
.profile-save {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  height: 78rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  overflow: hidden;
}

.profile-cancel {
  background: #eef0f4;
  color: #374151;
}

.profile-save {
  margin: 0;
  padding: 0;
  border: 0;
  background: linear-gradient(135deg, #8b5cf6, #6d28d9);
  color: #fff;
  box-shadow: 0 14rpx 24rpx rgba(109, 40, 217, 0.18);
  line-height: 78rpx;
  white-space: nowrap;
}

.profile-save::after {
  border: 0;
}

.profile-save[disabled] {
  opacity: 0.45;
}

.profile-login-tip {
  margin-top: 16rpx;
  color: #8b5cf6;
  font-size: 22rpx;
  line-height: 32rpx;
  text-align: center;
}

.profile-tip-overlay {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 3;
  transform: translate(-50%, -50%);
  max-width: calc(100% - 72rpx);
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.82);
  color: #fff;
  font-size: 24rpx;
  line-height: 34rpx;
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.18);
}
