<topbar title="确认支付" showBack="{{true}}" />
<scroll-view scroll-y class="page checkout-page">
  <view class="checkout-hero">
    <view class="hero-title">结算中转页</view>
    <view class="hero-sub">储值卡可在线抵扣，剩余金额进入微信支付</view>
  </view>

  <view class="summary-card">
    <view class="summary-row">
      <text>商品现金价</text>
      <text>¥{{preview.cashTotal}}</text>
    </view>
    <view class="summary-row" wx:if="{{preview.pointsUsed}}">
      <text>积分支付</text>
      <text>{{preview.pointsUsed}}积分</text>
    </view>
    <view class="summary-row" wx:if="{{useBalance}}">
      <text>储值卡抵扣</text>
      <text class="sub-green">-¥{{preview.balanceUsed}}</text>
    </view>
    <view class="summary-line"></view>
    <view class="summary-row total-row">
      <text>最终现金支付</text>
      <text class="total-amount">¥{{preview.payableTotal}}</text>
    </view>
  </view>

  <view class="method-card">
    <view class="method-top">
      <view>
        <view class="method-title">储值卡</view>
        <view class="method-desc">可用余额 ¥{{member.balance || 0}}</view>
      </view>
      <switch checked="{{useBalance}}" disabled="{{!(member.balance > 0)}}" color="#8b5cf6" bindchange="toggleBalance" />
    </view>
    <view class="method-tip">开启后将优先抵扣储值余额，剩余金额再进入微信支付。</view>
  </view>

  <view class="method-card">
    <view class="method-top">
      <view>
        <view class="method-title">积分</view>
        <view class="method-desc">可用 {{member.points || 0}} 积分 · 本单使用 {{preview.pointsUsed || 0}} 积分</view>
      </view>
      <switch checked="{{usePoints}}" disabled="{{!hasPointItems}}" color="#8b5cf6" bindchange="togglePoints" />
    </view>
    <view class="method-tip" wx:if="{{preview.pointsUsed}}">积分兑换按菜品设置的积分价格扣减。</view>
    <view class="method-tip" wx:if="{{!hasPointItems}}">本单商品暂未设置积分兑换价。</view>
    <view class="method-tip warning" wx:if="{{!preview.pointsEnough}}">当前积分不足，请返回购物车改用现金支付。</view>
  </view>

  <view class="detail-card">
    <view class="detail-title">支付明细</view>
    <view class="detail-row">
      <text>商品现金价</text>
      <text>¥{{preview.cashTotal}}</text>
    </view>
    <view class="detail-row" wx:if="{{preview.pointsUsed}}">
      <text>积分支付</text>
      <text>{{preview.pointsUsed}}积分</text>
    </view>
    <view class="detail-row" wx:if="{{preview.balanceUsed}}">
      <text>储值卡</text>
      <text>-¥{{preview.balanceUsed}}</text>
    </view>
    <view class="detail-row strong">
      <text>应付</text>
      <text>¥{{preview.payableTotal}}</text>
    </view>
  </view>

  <view class="items-card">
    <view class="detail-title">商品清单</view>
    <view class="item-row checkout-item-row" wx:for="{{cart}}" wx:key="cartKey">
      <view class="item-main">
        <text class="item-name">{{item.name}} x{{item.count}}</text>
      </view>
      <view class="item-price" wx:if="{{item.payType === 'points'}}">{{item.points || 0}}积分</view>
      <view class="item-price" wx:else>¥{{item.price}}.00</view>
    </view>
  </view>

  <view class="checkout-footer">
    <view class="footer-main">
      <text class="footer-label">实付</text>
      <text class="footer-amount">¥{{preview.payableTotal}}</text>
    </view>
    <button class="pay-btn" disabled="{{!preview.pointsEnough}}" bindtap="submitOrder" loading="{{paying}}">确认支付</button>
  </view>
</scroll-view>
