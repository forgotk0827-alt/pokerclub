.points-page {
  min-height: 100vh;
  padding: 24rpx 30rpx;
  background: #f7f7f7;
}

.points-card {
  height: 158rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #cf5d54;
  color: #fff;
}

.points-num {
  font-size: 54rpx;
  line-height: 62rpx;
  font-weight: 900;
}

.points-label {
  margin-top: 18rpx;
  font-size: 24rpx;
}
