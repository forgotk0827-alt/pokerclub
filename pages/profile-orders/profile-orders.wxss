.sub-page {
  min-height: 100vh;
}

.dark-page {
  background: #050807;
  color: #fff;
}

.tabs {
  height: 96rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  background: #fff;
  color: #111827;
}

.tab {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.tab-active {
  color: #e25754;
}

.tab-active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 56rpx;
  height: 5rpx;
  background: #e25754;
  transform: translateX(-50%);
}

.empty {
  padding-top: 56rpx;
  color: #8b919a;
  text-align: center;
  font-size: 26rpx;
}

.order-card {
  position: relative;
  margin: 22rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  background: #242526;
}

.order-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
}

.order-sub {
  margin-top: 10rpx;
  color: #a6a6a6;
  font-size: 24rpx;
}

.order-total {
  margin-top: 14rpx;
  color: #e25754;
  font-size: 30rpx;
  font-weight: 900;
}

.order-status {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  color: #e25754;
  font-size: 24rpx;
  font-weight: 800;
}
