.menu-page {
  height: calc(100vh - 128rpx);
  padding-bottom: 0;
  overflow: hidden;
  background: #050807;
}

.store-head {
  height: 92rpx;
  display: flex;
  align-items: center;
  background: #e25754;
}

.store-title {
  flex: 1;
  min-width: 0;
  height: 92rpx;
  padding-left: 10rpx;
  display: flex;
  align-items: center;
  color: #fff;
  font-size: 29rpx;
  line-height: 34rpx;
  font-weight: 800;
}

.arrow {
  flex: 0 0 auto;
  padding: 0 20rpx;
  font-size: 62rpx;
  line-height: 62rpx;
  font-weight: 300;
}

.table-badge {
  flex: 0 0 auto;
  margin-right: 16rpx;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
  font-size: 24rpx;
  line-height: 30rpx;
  font-weight: 900;
}

.search-box {
  position: relative;
  flex: 0 0 120rpx;
  width: 120rpx;
  height: 76rpx;
  margin-right: 20rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.search-box input {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  opacity: 0.01;
}

.search-lens {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  border: 7rpx solid #bdbdbd;
  border-radius: 50%;
}

.search-lens::after {
  content: "";
  position: absolute;
  right: -24rpx;
  bottom: -18rpx;
  width: 34rpx;
  height: 8rpx;
  border-radius: 8rpx;
  background: #bdbdbd;
  transform: rotate(45deg);
  transform-origin: left center;
}

.menu-shell {
  height: calc(100vh - 344rpx);
  display: grid;
  grid-template-columns: 240rpx minmax(0, 1fr);
  overflow: hidden;
  background: #050807;
}

.category-side {
  height: 100%;
  width: 240rpx;
  background: #050807;
}

.cat {
  position: relative;
  width: 100%;
  height: 98rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: #050807;
  font-size: 28rpx;
  line-height: 36rpx;
  font-weight: 900;
  text-align: center;
  overflow: hidden;
}

.cat text {
  display: block;
  width: 100%;
  padding: 0 18rpx;
  overflow: hidden;
  white-space: nowrap;
  text-align: center;
  text-overflow: clip;
}

.cat-active {
  color: #ef5b58;
  background: #222324;
}

.cat-active::before {
  content: "";
  position: absolute;
  left: 0;
  top: 36rpx;
  width: 7rpx;
  height: 42rpx;
  border-radius: 0 6rpx 6rpx 0;
  background: #d55652;
}

.content-side {
  min-width: 0;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: #050807;
}

.filter-row {
  height: 98rpx;
  flex: 0 0 98rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #050807;
}

.total-label {
  padding-left: 20rpx;
  color: #fff;
  font-size: 31rpx;
  line-height: 38rpx;
  font-weight: 800;
}

.sale-toggle {
  min-width: 214rpx;
  padding-right: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #fff;
  font-size: 26rpx;
  line-height: 32rpx;
  font-weight: 800;
}

.sale-checkbox {
  transform: scale(0.84);
}

.product-pane {
  flex: 1;
  min-height: 0;
  background: #050807;
}

.product-group {
  scroll-margin-top: 0;
}

.group-title {
  padding: 20rpx 20rpx 18rpx;
  color: #fff;
  font-size: 31rpx;
  line-height: 40rpx;
  font-weight: 900;
}

.group-card {
  background: #242526;
}

.menu-card {
  position: relative;
  min-height: 176rpx;
  padding: 22rpx 68rpx 22rpx 20rpx;
  display: flex;
  background: #242526;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.02);
}

.menu-img {
  flex: 0 0 132rpx;
  width: 132rpx;
  height: 132rpx;
  background: #111;
}

.menu-info {
  min-width: 0;
  flex: 1;
  padding-left: 18rpx;
}

.menu-topline {
  min-width: 0;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.menu-name {
  min-width: 0;
  flex: 1;
  color: #fff;
  font-size: 29rpx;
  line-height: 36rpx;
  font-weight: 900;
}

.menu-desc {
  margin-top: 8rpx;
  color: #a0a0a0;
  font-size: 25rpx;
  line-height: 31rpx;
  font-weight: 700;
}

.points {
  margin-top: 6rpx;
  color: #a9a9a9;
  font-size: 25rpx;
  line-height: 31rpx;
  font-weight: 800;
}

.points text {
  margin-right: 10rpx;
  color: #ef5b58;
  font-size: 34rpx;
  line-height: 38rpx;
  font-weight: 900;
}

.menu-price {
  margin-top: 10rpx;
  color: #ef5b58;
  font-size: 34rpx;
  line-height: 38rpx;
  font-weight: 900;
}

.menu-price text {
  font-size: 24rpx;
}

.menu-add {
  position: absolute;
  right: 18rpx;
  bottom: 24rpx;
  min-width: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ef5b58;
}

.point-add {
  position: absolute;
  right: 70rpx;
  bottom: 20rpx;
  min-width: 76rpx;
  height: 48rpx;
  padding: 0 16rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(239, 91, 88, 0.12);
  color: #ef5b58;
  font-size: 22rpx;
  font-weight: 900;
}

.plus-line {
  position: absolute;
  border-radius: 2rpx;
  background: #151515;
}

.plus-h {
  width: 18rpx;
  height: 5rpx;
}

.plus-v {
  width: 5rpx;
  height: 18rpx;
}

.disabled {
  opacity: 0.4;
}

.tag {
  flex: 0 0 auto;
  color: #aaa;
  font-size: 26rpx;
  line-height: 34rpx;
  font-weight: 800;
}

.empty {
  padding-top: 120rpx;
  color: #fff;
  text-align: center;
  font-size: 30rpx;
  font-weight: 800;
}

.menu-page,
.menu-shell,
.category-side,
.content-side,
.filter-row,
.product-pane {
  background: #0b0f10;
}

.store-head {
  background: #111719;
  box-shadow: 0 1rpx 0 rgba(255, 255, 255, 0.08);
}

.store-title {
  color: #f7f0df;
}

.table-badge {
  background: rgba(240, 193, 90, 0.14);
  color: #f0c15a;
}

.search-box {
  background: #f8f3e7;
}

.cat {
  background: #0b0f10;
  color: #b7c0c3;
}

.cat-active {
  color: #f0c15a;
  background: #1b2022;
}

.cat-active::before {
  background: #f0c15a;
}

.total-label,
.group-title {
  color: #f7f0df;
}

.group-card,
.menu-card {
  background: #1b2022;
}

.group-card {
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.24);
}

.menu-img {
  border-radius: 8rpx;
  background: #101415;
}

.menu-desc,
.points,
.tag {
  color: #aab3b6;
}

.points text,
.menu-price {
  color: #f0c15a;
}

.menu-add {
  background: #d74f45;
}

.menu-page,
.menu-shell,
.category-side,
.content-side,
.filter-row,
.product-pane {
  background: #120a1f;
}

.store-head {
  background: #1b102b;
}

.store-title,
.total-label,
.group-title {
  color: #f4ecff;
}

.table-badge {
  background: rgba(216, 180, 254, 0.16);
  color: #d8b4fe;
}

.search-box {
  background: #efe7ff;
}

.cat {
  background: #120a1f;
  color: #c6b8dc;
}

.cat-active {
  color: #d8b4fe;
  background: #241633;
}

.cat-active::before {
  background: #d8b4fe;
}

.group-card,
.menu-card {
  background: #241633;
}

.group-card {
  border-color: rgba(216, 180, 254, 0.13);
  box-shadow: 0 14rpx 34rpx rgba(24, 11, 39, 0.32);
}

.menu-img {
  background: #180f27;
}

.menu-desc,
.points,
.tag {
  color: #c6b8dc;
}

.points text,
.menu-price {
  color: #d8b4fe;
}

.menu-add {
  background: #8b5cf6;
}
