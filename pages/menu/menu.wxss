.menu-page {
  height: calc(100vh - 128rpx);
  padding-bottom: 124rpx;
  overflow: hidden;
}

.store-head {
  height: 92rpx;
  display: grid;
  grid-template-columns: 1fr 120rpx;
  align-items: center;
  background: #e25754;
}

.store-title {
  min-width: 0;
  height: 92rpx;
  padding-left: 22rpx;
  display: flex;
  align-items: center;
  color: #fff;
  font-size: 29rpx;
  font-weight: 800;
}

.arrow {
  padding: 0 18rpx;
  font-size: 58rpx;
  line-height: 58rpx;
}

.search-box {
  width: 150rpx;
  height: 68rpx;
  margin-right: 18rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 14rpx;
  background: #fff;
  color: #aaa;
}

.search-box input {
  flex: 1;
  height: 100%;
  margin-left: 10rpx;
  color: #222;
  font-size: 24rpx;
}

.search-box input::placeholder {
  color: #bbb;
}

.search-icon {
  flex: 0 0 auto;
  font-size: 46rpx;
  line-height: 46rpx;
}

.filter-row {
  height: 98rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #050807;
}

.total-label {
  padding-left: 220rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
}

.sale-toggle {
  padding-right: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #fff;
  font-size: 25rpx;
}

.menu-layout {
  height: calc(100vh - 442rpx);
  display: grid;
  grid-template-columns: 198rpx 1fr;
  overflow: hidden;
}

.category-side {
  height: 100%;
  background: #050807;
}

.cat {
  width: 198rpx;
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  background: #050807;
  border-left: 8rpx solid transparent;
}

.cat-active {
  color: #ef5b58;
  background: #222324;
  border-left-color: #ef5b58;
}

.product-pane {
  height: 100%;
  background: #050807;
}

.group-title {
  padding: 22rpx 20rpx;
  color: #fff;
  font-size: 31rpx;
  font-weight: 900;
}

.menu-card {
  position: relative;
  min-height: 168rpx;
  margin: 0 0 18rpx;
  padding: 22rpx 70rpx 22rpx 20rpx;
  display: flex;
  background: #242526;
}

.menu-img {
  flex: 0 0 132rpx;
  width: 132rpx;
  height: 132rpx;
  background: #111;
}

.menu-info {
  min-width: 0;
  flex: 1;
  padding-left: 18rpx;
}

.menu-name {
  color: #fff;
  font-size: 28rpx;
  line-height: 36rpx;
  font-weight: 900;
}

.menu-desc {
  margin-top: 8rpx;
  color: #a0a0a0;
  font-size: 24rpx;
  line-height: 31rpx;
}

.points {
  margin-top: 8rpx;
  color: #a9a9a9;
  font-size: 25rpx;
  font-weight: 800;
}

.menu-price {
  margin-top: 10rpx;
  color: #ef5b58;
  font-size: 34rpx;
  font-weight: 900;
}

.menu-price text {
  font-size: 24rpx;
}

.menu-add {
  position: absolute;
  right: 18rpx;
  bottom: 24rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ef5b58;
  color: #121212;
  font-size: 34rpx;
  font-weight: 900;
}

.disabled {
  opacity: 0.4;
}

.tag {
  position: absolute;
  right: 22rpx;
  top: 24rpx;
  color: #aaa;
  font-size: 25rpx;
  font-weight: 800;
}

.empty {
  padding-top: 120rpx;
  color: #fff;
  text-align: center;
  font-size: 30rpx;
  font-weight: 800;
}
