.info-page {
  min-height: 100vh;
  background: #f6f6f6;
}

.info-row {
  min-height: 100rpx;
  padding: 0 28rpx;
  display: grid;
  grid-template-columns: 160rpx minmax(0, 1fr) 36rpx;
  align-items: center;
  background: #fff;
  color: #111827;
  font-size: 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.avatar {
  justify-self: end;
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #9dadde;
  color: #fff;
  font-size: 34rpx;
}

.info-value {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: right;
  color: #8b919a;
}

.arrow {
  color: #8b919a;
  text-align: right;
  font-size: 54rpx;
  font-weight: 300;
}

.gap {
  height: 22rpx;
  background: #f6f6f6;
}
