        <view>
          <view class="editor-title">排行榜</view>
          <view class="muted-line">全门店统一展示。周榜每周日12点清零，月榜每月1号12点清零。</view>
        </view>
        <view class="rank-rule-chip">冠3 亚2 季1</view>
      </view>
      <view class="rank-tabs">
        <view class="rank-tab {{activeRankType === item.key ? 'active' : ''}}" wx:for="{{rankTabs}}" wx:for-item="item" wx:key="key" data-type="{{item.key}}" bindtap="selectRankType">{{item.label}}</view>
      </view>

      <view class="rank-operate-card">
        <view class="rank-operate-head">
          <view>
            <view class="rank-panel-title">选中玩家</view>
            <view class="muted-line" wx:if="{{selectedRankUser}}">{{selectedRankUser.username}} · {{selectedRankUser.score}} 分</view>
            <view class="muted-line" wx:else>先从下方榜单选择玩家，再进行加减分</view>
          </view>
          <view class="tag" wx:if="{{selectedRankUser}}">已选中</view>
        </view>
        <view class="rank-award-grid">
          <view class="solid-action award-first" data-score="3" bindtap="addRankAwardScore">冠军 +3</view>
          <view class="solid-action award-second" data-score="2" bindtap="addRankAwardScore">亚军 +2</view>
          <view class="solid-action award-third" data-score="1" bindtap="addRankAwardScore">季军 +1</view>
        </view>
        <view class="rank-adjust-row">
          <input value="{{rankDeltaScore}}" type="number" placeholder="输入分数" bindinput="inputRankDeltaScore" />
          <view class="solid-action" data-direction="add" bindtap="adjustRankScore">增加</view>
          <view class="solid-action dark" data-direction="deduct" bindtap="adjustRankScore">减少</view>
          <view class="ghost-action danger" bindtap="deleteRankUser">删除</view>
        </view>
      </view>

      <view class="rank-add-card">
        <view class="rank-panel-title">新增玩家</view>
        <view class="rank-add-row">
          <input value="{{rankUsername}}" placeholder="用户名" bindinput="inputRankUsername" />
          <input value="{{rankScore}}" type="number" placeholder="初始分" bindinput="inputRankScore" />
          <view class="solid-action" bindtap="addRankUser">新增</view>
        </view>
      </view>
    </view>

    <view class="rank-list-head">
      <view>排名</view>
      <view>玩家</view>
      <view>分数</view>
    </view>
    <view class="rank-row {{selectedRankUser && selectedRankUser.id === item.id ? 'rank-row-active' : ''}}" wx:for="{{leaderboard}}" wx:for-item="item" wx:key="id" data-id="{{item.id}}" bindtap="selectRankUser">
      <view class="rank-index {{index == 0 ? 'rank-top-one' : ''}} {{index == 1 ? 'rank-top-two' : ''}} {{index == 2 ? 'rank-top-three' : ''}}">{{item.rank}}</view>
      <view class="rank-main">
        <view class="item-title">{{item.username}}</view>
        <view class="muted-line">{{item.storeId || '全门店'}}</view>
      </view>
      <view class="rank-score">{{item.score}}</view>
      <view class="rank-move-group">
        <view class="move" data-id="{{item.id}}" data-direction="up" catchtap="moveRank">↑</view>
        <view class="move" data-id="{{item.id}}" data-direction="down" catchtap="moveRank">↓</view>
      </view>
    </view>
    <view wx:if="{{!leaderboard.length}}" class="empty">暂无排行数据</view>
  </view>

  <view wx:if="{{memberPickerVisible}}" class="member-picker-mask" bindtap="closeMemberPicker">
    <view class="member-picker-dialog" catchtap="noop">
      <view class="member-picker-head">
        <view>
          <view class="member-picker-title">{{memberPickerTitle}}</view>
          <view class="muted-line">{{memberPickerHint}}</view>
        </view>
        <view class="ghost-action mini-action" bindtap="closeMemberPicker">关闭</view>
      </view>
      <view wx:if="{{memberPickerSelectedId}}" class="selected-member">
        <view>
          <view class="item-title">{{memberPickerSelectedName}}</view>
          <view class="muted-line">会员ID {{memberPickerSelectedId}}</view>
        </view>
        <view class="tag">已选中</view>
      </view>
      <scroll-view scroll-y class="member-picker-list">
        <view class="member-picker-item {{memberPickerSelectedId === item.id ? 'member-picker-active' : ''}}" wx:for="{{memberPickerCandidates}}" wx:for-item="item" wx:key="id" data-id="{{item.id}}" bindtap="selectMemberCandidate">
          <view class="item-title">{{item.nickname || '未命名会员'}}</view>
          <view class="muted-line">会员ID {{item.id}} · 手机号 {{item.phone || '未绑定'}} · 余额 {{item.balance || 0}} · 积分 {{item.points || 0}} · 酒水券 {{item.drinkVoucherCount || 0}}</view>
        </view>
      </scroll-view>
      <view class="member-picker-actions">
        <view class="ghost-action" bindtap="closeMemberPicker">取消</view>
        <view class="solid-action" bindtap="confirmMemberPicker">{{memberPickerConfirmText}}</view>
      </view>
    </view>
  </view>
</view>
