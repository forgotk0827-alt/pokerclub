<topbar title="商家端" showBack="{{true}}" />
<view class="merchant-page">
  <view class="merchant-head">
    <view>
      <view class="shop-name">{{session.storeName}}</view>
      <view class="shop-sub">{{session.name}} · 新订单自动监听中</view>
    </view>
    <view class="logout" bindtap="logout">退出登录</view>
  </view>

  <picker wx:if="{{session.role === 'super_admin'}}" mode="selector" range="{{storeScopeOptions}}" range-key="name" bindchange="selectStoreScope">
    <view class="scope-picker">当前查看：{{selectedStoreName}}</view>
  </picker>

  <view class="summary-grid">
    <view class="summary-card">
      <text>{{orderCount}}</text>
      <view>本店订单</view>
    </view>
    <view class="summary-card">
      <text>{{cellar.length}}</text>
      <view>存酒</view>
    </view>
    <view class="summary-card">
      <text>{{signups.length}}</text>
      <view>活动报名</view>
    </view>
  </view>

  <scroll-view scroll-x class="tabs" enable-flex>
    <view wx:for="{{tabs}}" wx:for-item="tab" wx:key="*this" class="tab {{activeTab === tab ? 'tab-active' : ''}}" data-tab="{{tab}}" bindtap="switchTab">{{tab}}</view>
  </scroll-view>

  <view wx:if="{{activeTab === '订单'}}" class="panel">
    <scroll-view scroll-x class="status-tabs" enable-flex>
      <view wx:for="{{orderStatuses}}" wx:for-item="status" wx:key="*this" class="status-tab {{activeStatus === status ? 'status-active' : ''}}" data-status="{{status}}" bindtap="selectStatus">{{status}}</view>
    </scroll-view>
    <view wx:if="{{!orders.length}}" class="empty">暂无订单</view>
    <view class="order-card" wx:for="{{orders}}" wx:for-item="item" wx:key="id">
      <view class="card-top">
        <view class="item-title">{{item.id}}</view>
        <view class="tag">{{item.status}}</view>
      </view>
      <view class="muted-line">{{item.storeName}} · {{item.tableName || '未指定桌号'}} · {{item.createdAt}} · {{item.mode}} · ¥{{item.total}}</view>
      <view class="goods" wx:for="{{item.items}}" wx:for-item="goods" wx:key="id">
        {{goods.name}} · <text wx:if="{{goods.payType === 'points'}}">{{goods.points || goods.originPoints || 0}}积分</text><text wx:else>¥{{goods.price}}</text> x{{goods.count}}
      </view>
      <view class="muted-line" wx:if="{{item.originalTotal || item.voucherDiscount || item.balanceUsed || item.pointsUsed}}">
        原价 ¥{{item.originalTotal || item.total}}
        <text wx:if="{{item.voucherDiscount}}"> · 酒水券抵扣 ¥{{item.voucherDiscount}}</text>
        <text wx:if="{{item.balanceUsed}}"> · 储值卡抵扣 ¥{{item.balanceUsed}}</text>
        <text wx:if="{{item.pointsUsed}}"> · 积分 {{item.pointsUsed}}</text>
        <text> · 实付 ¥{{item.total}}</text>
      </view>
      <view class="action-row">
        <view class="ghost-action" data-id="{{item.id}}" bindtap="reprint">打印</view>
        <view class="ghost-action" data-id="{{item.id}}" bindtap="cancelOrder">取消</view>
        <view class="solid-action" data-id="{{item.id}}" bindtap="confirmOrder">确认</view>
        <view class="solid-action dark" data-id="{{item.id}}" bindtap="finishOrder">完成</view>
      </view>
    </view>
  </view>

  <view wx:elif="{{activeTab === '菜单管理'}}" class="panel">
    <view class="menu-editor">
      <view class="editor-title">{{menuForm.id ? '编辑餐品' : '新增餐品'}}</view>
      <view class="menu-form">
        <picker mode="selector" range="{{categories}}" range-key="name" value="{{menuForm.categoryIndex}}" bindchange="selectMenuCategory">
          <view class="picker-input">{{menuCategoryName}}</view>
        </picker>
        <input value="{{menuCategoryDraft}}" placeholder="新增类目名称" bindinput="inputMenuCategoryDraft" />
        <view class="solid-action" bindtap="addMenuCategory">添加类目</view>
      </view>
      <view class="category-list">
        <view class="category-chip" wx:for="{{categories}}" wx:for-item="item" wx:key="id">
          <text>{{item.name}}</text>
          <view class="ghost-action mini-action" data-id="{{item.id}}" data-direction="up" catchtap="moveMenuCategory">↑</view>
          <view class="ghost-action mini-action" data-id="{{item.id}}" data-direction="down" catchtap="moveMenuCategory">↓</view>
          <view class="ghost-action mini-action danger" data-id="{{item.id}}" catchtap="deleteMenuCategory">删除</view>
        </view>
      </view>
      <view class="dual-actions">
        <view class="ghost-action" bindtap="refreshProducts">刷新菜单</view>
        <view class="solid-action" bindtap="saveMenuSort">保存类目排序</view>
      </view>
      <view class="menu-form">
        <input value="{{menuForm.name}}" placeholder="餐品名称" data-field="name" bindinput="inputMenuField" />
        <input value="{{menuForm.price}}" type="digit" placeholder="价格" data-field="price" bindinput="inputMenuField" />
        <input value="{{menuForm.unit}}" placeholder="单位" data-field="unit" bindinput="inputMenuField" />
        <input value="{{menuForm.points}}" type="number" placeholder="积分兑换" data-field="points" bindinput="inputMenuField" />
      </view>
      <label class="sale-switch">
        <switch checked="{{menuForm.sale}}" color="#e25754" bindchange="toggleMenuSale" />
        <text>{{menuForm.sale ? '在售' : '下架'}}</text>
      </label>
      <view class="media-row">
        <view class="ghost-action" bindtap="chooseProductImage">上传商品图片</view>
        <image wx:if="{{menuForm.image}}" class="media-preview" src="{{menuForm.image}}" mode="aspectFill" />
      </view>
      <input class="desc-input" value="{{menuForm.desc}}" placeholder="餐品描述" data-field="desc" bindinput="inputMenuField" />
      <view class="dual-actions">
        <view class="ghost-action" bindtap="newProduct">清空新增</view>
        <view class="solid-action" bindtap="saveProduct">保存餐品</view>
      </view>
    </view>

    <view class="menu-manage-card" wx:for="{{products}}" wx:for-item="item" wx:key="id">
      <view class="card-top">
        <view class="item-title">{{item.name}}</view>
        <view class="tag">{{item.sale ? '在售' : '下架'}}</view>
      </view>
      <view class="muted-line">{{item.desc}}</view>
      <view class="muted-line">分类：{{item.categoryName}} · ¥{{item.price}}/{{item.unit}} · {{item.points || 0}}积分</view>
      <view class="action-row">
        <view class="solid-action" data-id="{{item.id}}" bindtap="editProduct">编辑</view>
        <view class="ghost-action danger" data-id="{{item.id}}" bindtap="deleteProduct">删除</view>
      </view>
    </view>
  </view>

  <view wx:elif="{{activeTab === '活动管理'}}" class="panel">
      <view class="menu-editor">
      <view class="editor-title">{{activityForm.id ? '编辑活动' : '新增活动'}}</view>
      <view class="form-grid">
        <input value="{{activityForm.title}}" placeholder="比赛名称" data-field="title" bindinput="inputActivityField" />
        <picker mode="selector" range="{{activityStoreOptions}}" range-key="name" value="{{activityStoreIndex}}" bindchange="selectActivityStore">
          <view class="picker-input">{{(activityStoreOptions[activityStoreIndex] && activityStoreOptions[activityStoreIndex].name) || '请选择比赛门店'}}</view>
        </picker>
      </view>
      <view class="muted-line">比赛地点：{{activityForm.location || '请选择门店后自动带出'}}</view>
      <view class="form-grid date-time-grid">
        <picker mode="date" value="{{activityForm.dateDate}}" data-prefix="date" data-part="date" bindchange="selectActivityDateTime">
          <view class="picker-input">{{activityForm.dateDate || '比赛日期'}}</view>
        </picker>
        <picker mode="time" value="{{activityForm.dateTime}}" data-prefix="date" data-part="time" bindchange="selectActivityDateTime">
          <view class="picker-input">{{activityForm.dateTime || '比赛时间'}}</view>
        </picker>
      </view>
      <view class="form-grid date-time-grid">
        <picker mode="date" value="{{activityForm.deadlineDate}}" data-prefix="deadline" data-part="date" bindchange="selectActivityDateTime">
          <view class="picker-input">{{activityForm.deadlineDate || '报名截止日期'}}</view>
        </picker>
        <picker mode="time" value="{{activityForm.deadlineTime}}" data-prefix="deadline" data-part="time" bindchange="selectActivityDateTime">
          <view class="picker-input">{{activityForm.deadlineTime || '报名截止时间'}}</view>
        </picker>
      </view>
      <view class="form-grid">
        <input value="{{activityForm.price}}" type="number" placeholder="活动价格" data-field="price" bindinput="inputActivityField" />
        <input value="{{activityForm.remainingQuota}}" type="number" placeholder="剩余名额" data-field="remainingQuota" bindinput="inputActivityField" />
      </view>
      <input class="desc-input" value="{{activityForm.dayLabel}}" placeholder="日期标签，如 今天/明天/后天" data-field="dayLabel" bindinput="inputActivityField" />
      <view class="muted-line">已报名：{{activityForm.joined || 0}}</view>
      <view class="dual-actions">
        <view class="ghost-action" data-id="{{activityForm.id}}" bindtap="duplicateActivity">复制活动</view>
        <view class="solid-action" bindtap="saveActivity">保存活动</view>
      </view>
    </view>

    <view class="menu-manage-card" wx:for="{{activities}}" wx:for-item="item" wx:key="id">
      <view class="card-top">
        <view class="item-title">{{item.title}}</view>
        <view class="tag">{{item.statusText || (item.status === 'open' ? '报名中' : '已截止')}}</view>
      </view>
      <view class="muted-line">{{item.date}} · {{item.location}}</view>
      <view class="muted-line">价格 ¥{{item.price || 0}} · 截止 {{item.deadlineAt || item.deadline || '未设置'}}</view>
      <view class="muted-line">已报 {{item.joined || 0}} · 剩余 {{item.remaining || item.remainingQuota || item.quota - item.joined || 0}}</view>
      <view class="action-row two-col">
        <view class="solid-action" data-id="{{item.id}}" bindtap="editActivity">编辑</view>
        <view class="ghost-action" data-id="{{item.id}}" bindtap="duplicateActivity">复制发布</view>
      </view>
    </view>
  </view>

  <view wx:elif="{{activeTab === '充值'}}" class="panel">
    <view class="menu-editor">
      <view class="editor-title">充值套餐设置</view>
      <view class="recharge-setting-grid">
        <input value="{{rechargeSettings.title}}" placeholder="页面标题" data-field="title" bindinput="inputRechargeSetting" />
        <input value="{{rechargeSettings.paymentLabel}}" placeholder="支付方式名称" data-field="paymentLabel" bindinput="inputRechargeSetting" />
      </view>
      <input class="desc-input" value="{{rechargeSettings.note}}" placeholder="充值提示文案" data-field="note" bindinput="inputRechargeSetting" />
      <view class="recharge-package" wx:for="{{rechargeSettings.packages}}" wx:for-item="item" wx:key="id">
        <view class="recharge-package-head">
          <view class="item-title">套餐 {{index + 1}}</view>
          <view class="ghost-action mini-action" data-index="{{index}}" bindtap="removeRechargePackage">删除</view>
        </view>
        <view class="recharge-package-grid">
          <input value="{{item.label}}" placeholder="标题" data-index="{{index}}" data-field="label" bindinput="inputRechargePackage" />
          <input value="{{item.subLabel}}" placeholder="副标题" data-index="{{index}}" data-field="subLabel" bindinput="inputRechargePackage" />
          <input value="{{item.payAmount}}" type="digit" placeholder="支付金额" data-index="{{index}}" data-field="payAmount" bindinput="inputRechargePackage" />
          <input value="{{item.creditAmount}}" type="digit" placeholder="到账金额" data-index="{{index}}" data-field="creditAmount" bindinput="inputRechargePackage" />
          <input value="{{item.voucherCount}}" type="number" placeholder="赠券张数" data-index="{{index}}" data-field="voucherCount" bindinput="inputRechargePackage" />
        </view>
        <input class="desc-input" value="{{item.tip}}" placeholder="赠送说明" data-index="{{index}}" data-field="tip" bindinput="inputRechargePackage" />
      </view>
      <view class="dual-actions">
        <view class="ghost-action" bindtap="addRechargePackage">新增套餐</view>
        <view class="solid-action" bindtap="saveRechargeSettings">保存设置</view>
      </view>
    </view>

    <view class="menu-editor">
      <view class="editor-title">手动调整余额</view>
      <view class="recharge-setting-grid">
        <input value="{{rechargeForm.memberKey}}" placeholder="会员ID" data-field="memberKey" bindinput="inputRechargeForm" />
        <input value="{{rechargeForm.delta}}" type="digit" placeholder="调整金额" data-field="delta" bindinput="inputRechargeForm" />
      </view>
      <input class="desc-input" value="{{rechargeForm.note}}" placeholder="调整备注" data-field="note" bindinput="inputRechargeForm" />
      <view class="dual-actions">
        <view class="solid-action" bindtap="adjustRechargeBalance">确认调整</view>
      </view>
    </view>

    <view class="sub-title">充值记录</view>
    <view wx:if="{{!rechargeRecords.length}}" class="empty small">暂无充值记录</view>
    <view class="recharge-record" wx:for="{{rechargeRecords}}" wx:for-item="item" wx:key="id">
      <view class="card-top">
        <view class="item-title">{{item.nickname || item.memberId}}</view>
        <view class="tag">{{item.type === 'recharge' ? '充值' : '调账'}}</view>
      </view>
      <view class="muted-line">{{item.createdAt}} · {{item.operator}}</view>
      <view class="muted-line">支付 ¥{{item.payAmount}} · 到账 {{item.creditAmount}} · 余额 {{item.balanceBefore}} → {{item.balanceAfter}}</view>
      <view class="muted-line" wx:if="{{item.note}}">{{item.note}}</view>
    </view>
  </view>

  <view wx:elif="{{activeTab === '数据管理'}}" class="panel">
    <view class="menu-editor">
      <view class="editor-title">数据概览</view>
      <view class="summary-grid">
        <view class="summary-card"><text>{{overview.storeCount}}</text><view>门店</view></view>
        <view class="summary-card"><text>{{overview.orderCount}}</text><view>订单</view></view>
        <view class="summary-card"><text>{{overview.memberCount}}</text><view>会员</view></view>
      </view>
      <view class="summary-grid">
        <view class="summary-card"><text>{{overview.cellarCount}}</text><view>存酒</view></view>
        <view class="summary-card"><text>{{overview.signupCount}}</text><view>报名</view></view>
        <view class="summary-card"><text>¥{{overview.totalSales}}</text><view>销售额</view></view>
      </view>
      <view class="muted-line">充值额 ¥{{overview.totalRecharge}}</view>
      <view class="dual-actions">
        <view class="ghost-action" bindtap="refreshDataManagement">刷新数据</view>
        <view class="solid-action" bindtap="exportStats">导出统计</view>
      </view>
    </view>

    <view class="sub-title">所有门店数据</view>
    <view class="basic-card">
      <view class="muted-line">订单、会员、存酒、报名数据均按门店汇总展示。</view>
    </view>

    <view class="sub-title">订单列表</view>
    <view wx:if="{{!allOrders.length}}" class="empty small">暂无订单</view>
    <view class="basic-card" wx:for="{{allOrders}}" wx:for-item="item" wx:key="id">
      <view class="card-top">
        <view class="item-title">{{item.id}}</view>
        <view class="tag">{{item.status}}</view>
      </view>
      <view class="muted-line">{{item.storeName}} · {{item.tableName || '未指定桌号'}} · {{item.createdAt}} · ¥{{item.total}}</view>
    </view>

    <view class="sub-title">会员列表</view>
    <view wx:if="{{!allMembers.length}}" class="empty small">暂无会员数据</view>
    <view class="basic-card" wx:for="{{allMembers}}" wx:for-item="item" wx:key="id">
      <view class="card-top">
        <view class="item-title">{{item.nickname}}</view>
        <view class="tag">余额 ¥{{item.balance || 0}}</view>
      </view>
      <view class="muted-line">会员ID {{item.id}} · 积分 {{item.points || 0}} · 来源 {{item.source || '会员'}}</view>
    </view>

    <view class="sub-title">存酒列表</view>
    <view wx:if="{{!allCellar.length}}" class="empty small">暂无存酒数据</view>
    <view class="basic-card" wx:for="{{allCellar}}" wx:for-item="item" wx:key="id">
      <view class="card-top">
        <view class="item-title">{{item.wineName}}</view>
        <view class="tag">{{item.status}}</view>
      </view>
      <view class="muted-line">{{item.storeName}} · {{item.quantity}} · 到期 {{item.expireAt}}</view>
    </view>
  </view>

  <view wx:elif="{{activeTab === '会员管理'}}" class="panel">
    <view class="menu-editor">
      <view class="editor-title">会员管理</view>
      <view class="form-grid">
        <input value="{{memberSearchKeyword}}" placeholder="搜索会员ID / 昵称 / 手机号" bindinput="inputMemberSearch" />
        <view class="ghost-action" bindtap="refreshMemberManagement">刷新会员</view>
      </view>
      <view class="muted-line">可查看余额、积分、碎片和酒水券，也可以打开详情查看消费、报名和存酒记录。</view>
      <view class="sub-title">积分与碎片调整</view>
      <view class="form-grid">
        <input value="{{pointsMemberKey}}" placeholder="会员ID / 手机号" bindinput="inputPointsMemberKey" />
        <input value="{{pointsDelta}}" type="number" placeholder="调整数量" bindinput="inputPointsDelta" />
      </view>
      <input class="desc-input" value="{{pointsReason}}" placeholder="调整备注" bindinput="inputPointsReason" />
      <view class="action-row">
        <view class="solid-action" bindtap="addMemberPoints">加积分</view>
        <view class="ghost-action danger" bindtap="deductMemberPoints">减积分</view>
        <view class="solid-action dark" bindtap="addMemberPieces">加碎片</view>
        <view class="ghost-action danger" bindtap="deductMemberPieces">减碎片</view>
      </view>
      <view class="sub-title">酒水券调整</view>
      <view class="muted-line">储值后自动进入背包；到店消费后由工作人员确认，再在这里增加或扣减客户酒水券。</view>
      <view class="form-grid">
        <input value="{{voucherForm.memberKey}}" placeholder="会员ID / 手机号" data-field="memberKey" bindinput="inputVoucherForm" />
        <input value="{{voucherForm.count}}" type="number" placeholder="数量" data-field="count" bindinput="inputVoucherForm" />
      </view>
      <input class="desc-input" value="{{voucherForm.note}}" placeholder="调整备注" data-field="note" bindinput="inputVoucherForm" />
      <view class="dual-actions">
        <view class="solid-action" bindtap="grantDrinkVoucher">增加酒水券</view>
        <view class="ghost-action danger" bindtap="deductDrinkVoucher">扣减酒水券</view>
      </view>
    </view>
    <view wx:if="{{!filteredMembers.length}}" class="empty small">暂无会员数据</view>
    <view class="member-pick-list">
      <view class="member-pick" wx:for="{{filteredMembers}}" wx:for-item="item" wx:key="id" data-id="{{item.id}}" bindtap="selectMember">
        <view>
          <view class="item-title">{{item.nickname || item.id}}</view>
          <view class="muted-line">余额 ¥{{item.balance || 0}} · 积分 {{item.points || 0}} · 碎片 {{item.invitePieces || 0}} · 酒水券 {{item.drinkVoucherCount || 0}}</view>
          <view class="muted-line">会员ID {{item.id}} · 手机号 {{item.phone || '未绑定'}}</view>
        </view>
        <view class="ghost-action mini-action">详情</view>
      </view>
    </view>
    <view wx:if="{{memberDetailVisible}}" class="member-detail-mask" bindtap="closeMemberDetail">
      <view class="member-detail-dialog" catchtap="noop">
        <view class="card-top">
          <view>
            <view class="item-title">{{selectedMember.nickname || '会员详情'}}</view>
            <view class="muted-line">会员ID {{selectedMember.id || '-'}} · {{selectedMember.phone || '未绑定手机号'}}</view>
          </view>
          <view class="ghost-action mini-action" bindtap="closeMemberDetail">关闭</view>
        </view>
        <view class="points-num">{{selectedMember.balance || 0}} 余额 · {{selectedMember.points || 0}} 积分 · {{selectedMember.invitePieces || 0}} 碎片 · {{selectedMember.drinkVoucherCount || 0}} 酒水券</view>
        <view class="muted-line">消费 {{selectedMember.orders.length || 0}} · 报名 {{selectedMember.signups.length || 0}} · 存酒 {{selectedMember.cellar.length || 0}} · 充值 {{selectedMember.rechargeRecords.length || 0}} · 酒水券流水 {{selectedMember.voucherLogs.length || 0}}</view>
        <scroll-view scroll-y class="member-detail-scroll">
          <view class="detail-block">
            <view class="sub-title">积分/碎片流水</view>
            <view class="muted-line" wx:if="{{!selectedMember.logs.length}}">暂无积分/碎片流水</view>
            <view class="log-row" wx:for="{{selectedMember.logs}}" wx:for-item="item" wx:key="id">
              <view>{{item.type === 'pieces' ? '碎片' : '积分'}} {{item.delta > 0 ? '+' : ''}}{{item.delta}}</view>
              <text>{{item.reason}} · {{item.createdAt}}</text>
            </view>
          </view>
          <view class="detail-block">
            <view class="sub-title">酒水券流水</view>
            <view class="muted-line" wx:if="{{!selectedMember.voucherLogs.length}}">暂无酒水券流水</view>
            <view class="detail-item" wx:for="{{selectedMember.voucherLogs}}" wx:for-item="item" wx:key="id">
              <view>酒水券 {{item.count > 0 ? '+' : ''}}{{item.count}}</view>
              <text>{{item.note}} · {{item.operator || '系统'}} · {{item.createdAt}}</text>
            </view>
          </view>
          <view class="detail-block">
            <view class="sub-title">充值记录</view>
            <view class="muted-line" wx:if="{{!selectedMember.rechargeRecords.length}}">暂无充值记录</view>
            <view class="detail-item" wx:for="{{selectedMember.rechargeRecords}}" wx:for-item="item" wx:key="id">
              <view>{{item.packageLabel || item.type || '充值'}} · {{item.status || item.payStatus || '已记录'}}</view>
              <text>{{item.createdAt}} · 支付 ¥{{item.payAmount || 0}} · 到账 ¥{{item.creditAmount || 0}} · 赠券 {{item.voucherCount || 0}}</text>
            </view>
          </view>
          <view class="detail-block">
            <view class="sub-title">消费记录</view>
            <view class="muted-line" wx:if="{{!selectedMember.orders.length}}">暂无消费记录</view>
            <view class="detail-item" wx:for="{{selectedMember.orders}}" wx:for-item="item" wx:key="id">
              <view>{{item.id}} · {{item.status}}</view>
              <text>{{item.createdAt}} · ¥{{item.total}}</text>
            </view>
          </view>
          <view class="detail-block">
            <view class="sub-title">报名记录</view>
            <view class="muted-line" wx:if="{{!selectedMember.signups.length}}">暂无报名记录</view>
            <view class="detail-item" wx:for="{{selectedMember.signups}}" wx:for-item="item" wx:key="id">
              <view>{{item.title}}</view>
              <text>{{item.date}} · {{item.status}}</text>
            </view>
          </view>
          <view class="detail-block">
            <view class="sub-title">存酒记录</view>
            <view class="muted-line" wx:if="{{!selectedMember.cellar.length}}">暂无存酒记录</view>
            <view class="detail-item" wx:for="{{selectedMember.cellar}}" wx:for-item="item" wx:key="id">
              <view>{{item.wineName}}</view>
              <text>{{item.quantity}} · {{item.status}} · {{item.expireAt}}</text>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>

  <view wx:elif="{{activeTab === '桌码'}}" class="panel">
    <view class="menu-editor">
      <view class="editor-title">桌台小程序码</view>
      <view class="muted-line">客户扫码后会自动进入对应门店和桌号。</view>
      <view class="muted-line">已生成 {{tableQrcodeCount}} / {{tableQrcodes.length}}</view>
      <view class="dual-actions">
        <view class="ghost-action" bindtap="refreshTableQrcodes">刷新桌码</view>
        <view class="solid-action" bindtap="generateTableQrcodes">生成桌码</view>
      </view>
    </view>
    <view class="basic-card" wx:for="{{tableQrcodes}}" wx:for-item="item" wx:key="id">
      <view class="card-top">
        <view class="item-title">桌号 {{item.tableNo}}</view>
        <view class="tag">{{item.exists ? '已生成' : '未生成'}}</view>
      </view>
      <view class="muted-line">{{item.storeName}}</view>
    </view>
  </view>

  <view wx:elif="{{activeTab === '轮播条'}}" class="panel">
    <view class="menu-editor">
      <view class="editor-title">首页滚动轮播条</view>
      <textarea class="desc-input textarea-input" value="{{globalSettings.homeNotice}}" placeholder="输入首页顶部横向滚动播放的文字" data-field="homeNotice" bindinput="inputGlobalSetting"></textarea>
      <view class="dual-actions">
        <view class="ghost-action" bindtap="refreshGlobalSettings">刷新</view>
        <view class="solid-action" bindtap="saveNoticeSettings">发布轮播条</view>
      </view>
    </view>
  </view>

  <view wx:elif="{{activeTab === '精彩呈现'}}" class="panel">
    <view class="menu-editor">
      <view class="editor-title">精彩呈现</view>
      <view class="form-grid">
        <input value="{{globalSettings.videoTitle}}" placeholder="视频标题" data-field="videoTitle" bindinput="inputGlobalSetting" />
        <view class="ghost-action" bindtap="chooseGlobalVideo">上传门店视频</view>
      </view>
      <textarea class="desc-input textarea-input" value="{{globalSettings.showcaseText}}" placeholder="前台展示文案" data-field="showcaseText" bindinput="inputGlobalSetting"></textarea>
      <view class="muted-line">视频地址：{{globalSettings.videoUrl || '未上传'}}</view>
      <view class="dual-actions">
        <view class="ghost-action" bindtap="refreshGlobalSettings">刷新</view>
        <view class="solid-action" bindtap="saveShowcaseSettings">保存展示</view>
      </view>
    </view>
  </view>

  <view wx:elif="{{activeTab === '加入我们'}}" class="panel">
    <view class="menu-editor">
      <view class="editor-title">加入我们</view>
      <view class="form-grid">
        <input value="{{globalSettings.joinUsTitle}}" placeholder="标题" data-field="joinUsTitle" bindinput="inputGlobalSetting" />
        <view class="ghost-action" bindtap="chooseJoinUsImage">上传配图</view>
      </view>
      <textarea class="desc-input textarea-input" value="{{globalSettings.joinUsText}}" placeholder="展示文案" data-field="joinUsText" bindinput="inputGlobalSetting"></textarea>
      <image wx:if="{{globalSettings.joinUsImage}}" class="media-preview large-preview" src="{{globalSettings.joinUsImage}}" mode="aspectFill" />
      <view class="dual-actions">
        <view class="ghost-action" bindtap="refreshGlobalSettings">刷新</view>
        <view class="solid-action" bindtap="saveJoinUsSettings">保存内容</view>
      </view>
    </view>
  </view>

  <view wx:elif="{{activeTab === '通用设置'}}" class="panel">
    <view class="menu-editor">
      <view class="editor-title">通用设置</view>
      <view class="form-grid">
        <input value="{{globalSettings.videoTitle}}" placeholder="视频标题" data-field="videoTitle" bindinput="inputGlobalSetting" />
        <input value="{{globalSettings.reminderInterval}}" type="number" placeholder="提醒间隔(分钟)" data-field="reminderInterval" bindinput="inputGlobalSetting" />
      </view>
      <input class="desc-input" value="{{globalSettings.newOrderReminder}}" placeholder="新订单提醒规则" data-field="newOrderReminder" bindinput="inputGlobalSetting" />
      <input class="desc-input" value="{{globalSettings.newOrderReminderText}}" placeholder="提醒文案模板" data-field="newOrderReminderText" bindinput="inputGlobalSetting" />
      <input class="desc-input" value="{{globalSettings.newOrderVoiceUrl}}" placeholder="语音地址" data-field="newOrderVoiceUrl" bindinput="inputGlobalSetting" />
      <textarea class="desc-input textarea-input receipt-template-input" value="{{globalSettings.printTemplate}}" placeholder="小票模板" data-field="printTemplate" bindinput="inputGlobalSetting"></textarea>
      <view class="dual-actions">
        <view class="ghost-action" bindtap="refreshGlobalSettings">刷新</view>
        <view class="solid-action" bindtap="saveGlobalSettings">保存通用设置</view>
      </view>
      <view class="dual-actions">
        <view class="ghost-action" bindtap="testNewOrderReminder">测试提醒</view>
      </view>
    </view>
  </view>

  <view wx:elif="{{activeTab === '门店管理'}}" class="panel">
    <view class="menu-editor">
      <view class="editor-title">门店信息</view>
      <view class="form-grid">
        <input value="{{storeForm.name}}" placeholder="门店名称" data-field="name" bindinput="inputStoreField" />
        <input value="{{storeForm.shortName}}" placeholder="门店简称" data-field="shortName" bindinput="inputStoreField" />
      </view>
      <input class="desc-input" value="{{storeForm.address}}" placeholder="门店地址" data-field="address" bindinput="inputStoreField" />
      <view class="form-grid">
        <input value="{{storeForm.phone}}" placeholder="联系电话" data-field="phone" bindinput="inputStoreField" />
        <input value="{{storeForm.status}}" placeholder="状态" data-field="status" bindinput="inputStoreField" />
      </view>
      <view class="form-grid">
        <input value="{{storeForm.printerSn}}" placeholder="打印机 SN" data-field="printerSn" bindinput="inputStoreField" />
        <input value="{{storeForm.printerName}}" placeholder="打印机名称" data-field="printerName" bindinput="inputStoreField" />
      </view>
      <input class="desc-input" value="{{storeForm.printerCopies}}" type="number" placeholder="默认打印份数" data-field="printerCopies" bindinput="inputStoreField" />
      <view class="dual-actions">
        <view class="ghost-action" bindtap="chooseStoreLocation">地图选点</view>
        <view class="solid-action" bindtap="saveStore">保存门店</view>
      </view>
      <view class="dual-actions">
        <view class="ghost-action" bindtap="newStore">新建门店</view>
      </view>
    </view>

    <view class="sub-title">现有门店</view>
    <view class="basic-card" wx:for="{{stores}}" wx:for-item="item" wx:key="id">
      <view class="card-top">
        <view class="item-title">{{item.shortName || item.name}}</view>
        <view class="tag">{{item.status}}</view>
      </view>
      <view class="muted-line">{{item.name}}</view>
      <view class="muted-line">{{item.address}}</view>
      <view class="muted-line">打印机：{{item.printerName || item.printerSn || '未配置'}}</view>
      <view class="action-row two-col">
        <view class="solid-action" data-id="{{item.id}}" bindtap="editStore">编辑</view>
        <view class="ghost-action danger" data-id="{{item.id}}" bindtap="deleteStore">删除</view>
      </view>
    </view>
  </view>

  <view wx:elif="{{activeTab === '基础'}}" class="panel">
    <view class="sub-title">存酒申请</view>
    <view wx:if="{{!cellar.length}}" class="empty small">暂无存酒</view>
    <view class="basic-card" wx:for="{{cellar}}" wx:for-item="item" wx:key="id">
      <view class="card-top">
        <view class="item-title">{{item.wineName}}</view>
        <view class="tag">{{item.status}}</view>
      </view>
      <view class="muted-line">{{item.storeName}} · {{item.quantity}} · 到期 {{item.expireAt}}</view>
      <view class="action-row">
        <view class="ghost-action" data-id="{{item.id}}" data-status="已提取" bindtap="handleCellar">提取</view>
        <view class="solid-action" data-id="{{item.id}}" data-status="存放中" bindtap="handleCellar">存放中</view>
      </view>
    </view>

    <view class="sub-title">桌游预约</view>
    <view wx:if="{{!reservations.length}}" class="empty small">暂无预约</view>
    <view class="basic-card" wx:for="{{reservations}}" wx:for-item="item" wx:key="id">
      <view class="item-title">{{item.id}}</view>
      <view class="muted-line">{{item.createdAt}} · {{item.status}} · ¥{{item.total}}</view>
    </view>

    <view class="sub-title">活动报名</view>
    <view wx:if="{{!signups.length}}" class="empty small">暂无报名</view>
    <view class="basic-card" wx:for="{{signups}}" wx:for-item="item" wx:key="id">
      <view class="card-top">
        <view class="item-title">{{item.title}}</view>
        <view class="tag">{{item.status}}</view>
      </view>
      <view class="muted-line">{{item.date}} · ¥{{item.price || 0}}</view>
      <view class="action-row">
        <view class="ghost-action" data-id="{{item.id}}" data-status="已取消" bindtap="handleSignup">取消</view>
        <view class="solid-action" data-id="{{item.id}}" data-status="已确认" bindtap="handleSignup">确认</view>
      </view>
    </view>
  </view>

  <view wx:elif="{{activeTab === '库存'}}" class="panel">
    <view class="menu-editor">
      <view class="editor-title">库存管理</view>
      <view class="muted-line">直接输入库存数量后点保存即可。</view>
    </view>
    <view class="stock-row" wx:for="{{inventory}}" wx:for-item="item" wx:key="id">
      <view class="stock-main">
        <view class="item-title">{{item.name}}</view>
        <view class="muted-line">当前库存 {{item.stock}}</view>
      </view>
      <view class="stock-actions">
        <input class="stock-input" type="number" value="{{item.draftStock}}" data-id="{{item.id}}" bindinput="inputStock" />
        <view class="solid-action mini-stock" data-id="{{item.id}}" bindtap="saveStock">保存</view>
      </view>
    </view>
  </view>

  <view wx:elif="{{activeTab === '排行'}}" class="panel">
    <view class="menu-editor">
      <view class="editor-title">排行榜</view>
      <view class="muted-line">全门店统一展示。周榜不清零，月榜每月1号12点清零；小型比赛冠军+3分，亚军+2分，季军+1分。</view>
      <view class="rank-tabs">
        <view class="rank-tab {{activeRankType === item.key ? 'active' : ''}}" wx:for="{{rankTabs}}" wx:for-item="item" wx:key="key" data-type="{{item.key}}" bindtap="selectRankType">{{item.label}}</view>
      </view>
      <view class="rank-form">
        <input value="{{rankUsername}}" placeholder="用户名" bindinput="inputRankUsername" />
        <input value="{{rankScore}}" type="number" placeholder="分数" bindinput="inputRankScore" />
        <view class="solid-action" bindtap="addRankUser">新增</view>
      </view>
      <view class="rank-form">
        <input value="{{rankDeltaScore}}" type="number" placeholder="增减分数" bindinput="inputRankDeltaScore" />
        <view class="solid-action" bindtap="addRankScore">调整分数</view>
        <view class="ghost-action danger" bindtap="deleteRankUser">删除</view>
      </view>
      <view class="dual-actions rank-award-actions">
        <view class="solid-action" data-score="3" bindtap="addRankAwardScore">冠军 +3</view>
        <view class="solid-action dark" data-score="2" bindtap="addRankAwardScore">亚军 +2</view>
        <view class="ghost-action" data-score="1" bindtap="addRankAwardScore">季军 +1</view>
      </view>
      <view wx:if="{{selectedRankUser}}" class="selected-member">
        <view>
          <view class="item-title">{{selectedRankUser.username}}</view>
          <view class="muted-line">当前分数 {{selectedRankUser.score}} · 门店 {{selectedRankUser.storeId || '全部'}}</view>
        </view>
        <view class="tag">已选中</view>
      </view>
    </view>

    <view class="rank-row" wx:for="{{leaderboard}}" wx:for-item="item" wx:key="id" data-id="{{item.id}}" bindtap="selectRankUser">
      <view class="rank-index">{{item.rank}}</view>
      <view class="rank-main">
        <view class="item-title">{{item.username}}</view>
        <view class="muted-line">{{item.score}} 分</view>
      </view>
      <view class="move" data-id="{{item.id}}" data-direction="up" catchtap="moveRank">↑</view>
      <view class="move" data-id="{{item.id}}" data-direction="down" catchtap="moveRank">↓</view>
    </view>
  </view>

  <view wx:if="{{memberPickerVisible}}" class="member-picker-mask" bindtap="closeMemberPicker">
    <view class="member-picker-dialog" catchtap="noop">
      <view class="member-picker-head">
        <view>
          <view class="member-picker-title">{{memberPickerTitle}}</view>
          <view class="muted-line">{{memberPickerHint}}</view>
        </view>
        <view class="ghost-action mini-action" bindtap="closeMemberPicker">关闭</view>
      </view>
      <view wx:if="{{memberPickerSelectedId}}" class="selected-member">
        <view>
          <view class="item-title">{{memberPickerSelectedName}}</view>
          <view class="muted-line">会员ID {{memberPickerSelectedId}}</view>
        </view>
        <view class="tag">已选中</view>
      </view>
      <scroll-view scroll-y class="member-picker-list">
        <view class="member-picker-item {{memberPickerSelectedId === item.id ? 'member-picker-active' : ''}}" wx:for="{{memberPickerCandidates}}" wx:for-item="item" wx:key="id" data-id="{{item.id}}" bindtap="selectMemberCandidate">
          <view class="item-title">{{item.nickname || '未命名会员'}}</view>
          <view class="muted-line">会员ID {{item.id}} · 手机号 {{item.phone || '未绑定'}} · 余额 {{item.balance || 0}} · 积分 {{item.points || 0}} · 酒水券 {{item.drinkVoucherCount || 0}}</view>
        </view>
      </scroll-view>
      <view class="member-picker-actions">
        <view class="ghost-action" bindtap="closeMemberPicker">取消</view>
        <view class="solid-action" bindtap="confirmMemberPicker">{{memberPickerConfirmText}}</view>
      </view>
    </view>
  </view>
</view>
