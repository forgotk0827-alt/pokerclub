.merchant-page {
  min-height: 100vh;
  padding: 22rpx 22rpx 56rpx;
  background: #f4f5f7;
  color: #111827;
}

.merchant-head {
  padding: 24rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #1f2429;
  color: #fff;
}

.shop-name {
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.shop-sub {
  margin-top: 8rpx;
  color: #c8ced6;
  font-size: 24rpx;
}

.logout {
  width: 120rpx;
  height: 52rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.12);
  font-size: 24rpx;
  font-weight: 800;
  white-space: nowrap;
}

.summary-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.scope-picker {
  height: 64rpx;
  margin-top: 16rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  background: #fff;
  color: #111827;
  font-size: 25rpx;
  font-weight: 900;
}

.summary-card {
  height: 118rpx;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.summary-card text {
  font-size: 34rpx;
  font-weight: 900;
}

.summary-card view {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 23rpx;
}

.tabs,
.status-tabs {
  width: 100%;
  white-space: nowrap;
}

.tabs {
  margin-top: 20rpx;
}

.tab,
.status-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #fff;
  color: #374151;
  font-weight: 900;
}

.tab {
  width: 126rpx;
  height: 66rpx;
  margin-right: 12rpx;
  font-size: 26rpx;
}

.tab-active,
.status-active {
  background: #e25754;
  color: #fff;
}

.panel {
  margin-top: 18rpx;
}

.status-tab {
  min-width: 118rpx;
  height: 58rpx;
  margin-right: 10rpx;
  font-size: 24rpx;
}

.order-card,
.basic-card,
.member-card,
.menu-editor,
.menu-manage-card,
.recharge-record,
.stock-row,
.rank-row,
.log-row {
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #fff;
}

.card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.item-title {
  min-width: 0;
  color: #111827;
  font-size: 28rpx;
  line-height: 38rpx;
  font-weight: 900;
  word-break: break-all;
}

.tag {
  min-width: 92rpx;
  height: 40rpx;
  padding: 0 12rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff1f1;
  color: #e25754;
  font-size: 22rpx;
  font-weight: 900;
}

.muted-line {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 34rpx;
}

.goods {
  margin-top: 8rpx;
  color: #374151;
  font-size: 24rpx;
  line-height: 34rpx;
}

.action-row,
.dual-actions {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
}

.dual-actions {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.rank-award-actions {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.rank-dashboard {
  margin-top: 16rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  background: #fff;
}

.rank-head,
.rank-operate-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.rank-rule-chip {
  flex: 0 0 auto;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  background: #111827;
  color: #fff;
  font-size: 22rpx;
  font-weight: 900;
}

.rank-operate-card,
.rank-add-card {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #f9fafb;
  border: 1rpx solid #eef0f3;
}

.rank-panel-title {
  color: #111827;
  font-size: 26rpx;
  line-height: 34rpx;
  font-weight: 900;
}

.rank-award-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.award-first {
  background: #e25754;
}

.award-second {
  background: #1f2429;
}

.award-third {
  background: #6b7280;
}

.rank-adjust-row,
.rank-add-row {
  margin-top: 14rpx;
  display: grid;
  gap: 10rpx;
  align-items: center;
}

.rank-adjust-row {
  grid-template-columns: minmax(0, 1.1fr) repeat(3, minmax(0, 1fr));
}

.rank-add-row {
  grid-template-columns: minmax(0, 1.35fr) minmax(0, 0.9fr) minmax(0, 0.8fr);
}

.rank-adjust-row input,
.rank-add-row input {
  height: 58rpx;
  padding: 0 16rpx;
  border-radius: 8rpx;
  background: #fff;
  border: 1rpx solid #e5e7eb;
  font-size: 24rpx;
}

.ghost-action,
.solid-action {
  height: 58rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.ghost-action {
  border: 1rpx solid #e5e7eb;
  color: #374151;
}

.solid-action {
  background: #e25754;
  color: #fff;
}

.solid-action.dark {
  background: #1f2429;
}

.danger {
  color: #e25754;
}

.danger-action {
  border-color: rgba(226, 87, 84, 0.36);
  color: #e25754;
}

.empty {
  margin-top: 18rpx;
  padding: 70rpx 0;
  border-radius: 8rpx;
  background: #fff;
  color: #9ca3af;
  text-align: center;
  font-size: 26rpx;
}

.empty.small {
  padding: 36rpx 0;
}

.points-num {
  margin-top: 10rpx;
  color: #e25754;
  font-size: 34rpx;
  font-weight: 900;
}

.selected-member,
.member-pick {
  margin-top: 12rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.selected-member {
  border: 1rpx solid #f5b6a4;
  background: #fff7f2;
}

.member-pick-list {
  display: grid;
  gap: 10rpx;
}

.stock-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.stock-input {
  width: 160rpx;
  height: 60rpx;
  padding: 0 16rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  background: #fff;
  box-sizing: border-box;
}

.mini-stock {
  min-width: 96rpx;
}

.mini-action {
  min-width: 96rpx;
  padding: 0 18rpx;
}

.form-grid,
.menu-form,
.rank-form {
  margin-top: 16rpx;
  display: grid;
  gap: 12rpx;
}

.form-grid {
  grid-template-columns: 180rpx minmax(0, 1fr);
}

.date-time-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.rank-form {
  grid-template-columns: minmax(0, 1fr) 150rpx 96rpx;
}

.rank-tabs {
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.rank-tab {
  height: 58rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f0ff;
  color: #6d28d9;
  font-size: 24rpx;
  font-weight: 800;
}

.rank-tab.active {
  background: #8b5cf6;
  color: #fff;
}

.menu-form {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.category-list {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.category-chip {
  width: 100%;
  min-height: 52rpx;
  padding: 8rpx 12rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  display: inline-flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  background: #f9fafb;
  box-sizing: border-box;
}

.category-chip text {
  flex: 1 1 auto;
  color: #111827;
  font-size: 24rpx;
  font-weight: 900;
}

.recharge-setting-grid,
.recharge-package-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.recharge-package-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  align-items: start;
}

.recharge-guide {
  margin-top: 14rpx;
  padding: 18rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 8rpx;
  background: #eff6ff;
}

.guide-title {
  color: #1e3a8a;
  font-size: 26rpx;
  line-height: 34rpx;
  font-weight: 900;
}

.guide-line {
  margin-top: 8rpx;
  color: #1f2937;
  font-size: 24rpx;
  line-height: 34rpx;
}

.field-block {
  min-width: 0;
}

.full-field {
  margin-top: 14rpx;
}

.field-label {
  margin-bottom: 8rpx;
  color: #111827;
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 900;
}

.field-help {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 30rpx;
}

.image-actions {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.recharge-package {
  margin-top: 16rpx;
  padding: 18rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  background: #fbfbfc;
}

.recharge-package-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.package-summary {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.package-summary view {
  min-height: 58rpx;
  padding: 8rpx 10rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #111827;
  color: #fff;
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 900;
  text-align: center;
}

.voucher-preview {
  min-height: 154rpx;
  margin-top: 16rpx;
  border-radius: 8rpx;
  display: grid;
  grid-template-columns: 150rpx minmax(0, 1fr) 86rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.06);
}

.voucher-preview-count {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #fff6dc 0%, #fff 100%);
  color: #a11f1f;
  font-size: 34rpx;
  font-weight: 900;
}

.voucher-preview-main {
  min-width: 0;
  padding: 18rpx 16rpx;
  color: #6b7280;
}

.voucher-preview-title {
  color: #4b5563;
  font-size: 26rpx;
  line-height: 34rpx;
  font-weight: 900;
}

.voucher-preview-rule,
.voucher-preview-note,
.voucher-preview-expire {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 30rpx;
}

.voucher-preview-rule {
  color: #374151;
}

.voucher-preview-action {
  border-left: 1rpx solid #ececec;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #d97706;
  font-size: 24rpx;
  line-height: 30rpx;
  font-weight: 900;
  writing-mode: vertical-rl;
}

.mini-action {
  width: 92rpx;
  height: 48rpx;
  flex: 0 0 auto;
}

.location-box {
  height: 72rpx;
  margin-top: 12rpx;
  border: 1rpx dashed #e25754;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff7f7;
  color: #e25754;
  font-size: 26rpx;
  font-weight: 900;
}

input {
  height: 66rpx;
  padding: 0 16rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  background: #fff;
  color: #111827;
  font-size: 24rpx;
}

.editor-title {
  color: #111827;
  font-size: 30rpx;
  line-height: 40rpx;
  font-weight: 900;
}

.picker-input {
  height: 66rpx;
  padding: 0 16rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  background: #fff;
  color: #111827;
  font-size: 24rpx;
}

.sale-switch {
  height: 66rpx;
  padding: 0 14rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  color: #374151;
  font-size: 24rpx;
  font-weight: 900;
}

.desc-input {
  width: 100%;
  margin-top: 12rpx;
}

.field-block .desc-input {
  margin-top: 0;
}

.textarea-input {
  min-height: 150rpx;
  padding: 18rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  box-sizing: border-box;
  background: #fff;
  color: #111827;
  font-size: 24rpx;
  line-height: 36rpx;
}

.receipt-template-input {
  min-height: 360rpx;
}

.media-row {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: 220rpx minmax(0, 1fr);
  gap: 14rpx;
  align-items: center;
}

.media-preview {
  width: 180rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: #f3f4f6;
}

.showcase-image-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.showcase-image-item {
  min-width: 0;
}

.showcase-image-item .media-preview {
  width: 100%;
  height: 126rpx;
  display: block;
}

.showcase-image-item .mini-action {
  margin-top: 8rpx;
  width: 100%;
}

.large-preview {
  width: 260rpx;
  height: 170rpx;
}

.video-preview {
  width: 320rpx;
  height: 180rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #111827;
}

.two-col {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.three-col {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.sub-title {
  margin: 28rpx 4rpx 12rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.log-row {
  margin-top: 10rpx;
}

.log-row view {
  color: #111827;
  font-size: 25rpx;
  font-weight: 900;
}

.log-row text {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 23rpx;
}

.stock-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 16rpx;
  align-items: center;
}

.stock-main {
  min-width: 0;
}

.move {
  height: 54rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f4f6;
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
}

.rank-row {
  display: grid;
  grid-template-columns: 58rpx minmax(0, 1fr) 92rpx 118rpx;
  gap: 14rpx;
  align-items: center;
  border: 1rpx solid transparent;
}

.rank-row-active {
  border-color: rgba(226, 87, 84, 0.46);
  background: #fff8f8;
}

.rank-list-head {
  margin-top: 18rpx;
  padding: 0 20rpx;
  height: 48rpx;
  display: grid;
  grid-template-columns: 58rpx minmax(0, 1fr) 92rpx 118rpx;
  gap: 14rpx;
  align-items: center;
  color: #6b7280;
  font-size: 22rpx;
  font-weight: 900;
}

.rank-index {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e25754;
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
}

.rank-top-one {
  background: #eab308;
}

.rank-top-two {
  background: #6b7280;
}

.rank-top-three {
  background: #a16207;
}

.rank-main {
  min-width: 0;
}

.rank-score {
  color: #e25754;
  font-size: 34rpx;
  font-weight: 900;
  text-align: right;
}

.rank-move-group {
  display: grid;
  grid-template-columns: repeat(2, 54rpx);
  gap: 8rpx;
  justify-content: end;
}

.member-detail-mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  padding: 24rpx;
  background: rgba(17, 24, 39, 0.56);
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.member-detail-dialog {
  width: 100%;
  height: 82vh;
  max-height: 980rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  box-sizing: border-box;
}

.member-detail-scroll {
  flex: 1;
  min-height: 0;
}

.detail-block {
  margin-top: 12rpx;
}

.detail-item {
  margin-top: 10rpx;
  padding: 14rpx 16rpx;
  border-radius: 8rpx;
  background: #fff;
}

.detail-item view {
  color: #111827;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.detail-item text {
  display: block;
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 32rpx;
}

.member-picker-mask {
  position: fixed;
  inset: 0;
  z-index: 60;
  padding: 24rpx;
  background: rgba(17, 24, 39, 0.58);
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.member-picker-dialog {
  width: 100%;
  max-height: 86vh;
  padding: 22rpx;
  border-radius: 8rpx;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  box-sizing: border-box;
}

.member-picker-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.member-picker-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.member-picker-list {
  flex: 1;
  min-height: 0;
  max-height: 58vh;
}

.member-picker-item {
  margin-top: 12rpx;
  padding: 18rpx 16rpx;
  border-radius: 8rpx;
  background: #fff;
  border: 1rpx solid transparent;
}

.member-picker-active {
  border-color: #e25754;
  background: #fff7f7;
}

.member-picker-actions {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 16rpx;
}
