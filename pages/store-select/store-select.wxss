.store-select-page {
  min-height: calc(100vh - 76px);
  padding: 24rpx 22rpx 40rpx;
  background: #050807;
}

.store-tabs {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0 24rpx;
  background: #fff;
}

.store-tab {
  flex: 1;
  text-align: center;
  color: #111;
  font-size: 31rpx;
  font-weight: 900;
}

.store-tab-active {
  color: #0f172a;
}

.store-list {
  margin-top: 22rpx;
}

.store-card {
  overflow: hidden;
  border-radius: 18rpx;
  background: #fff;
}

.store-cover {
  width: 100%;
  height: 334rpx;
  display: block;
  background: #111;
}

.store-card-body {
  padding: 24rpx 22rpx 22rpx;
}

.store-card-title {
  color: #111827;
  font-size: 32rpx;
  line-height: 42rpx;
  font-weight: 900;
}

.store-card-sub {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 28rpx;
  font-weight: 800;
}

.store-card-line {
  margin-top: 14rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 32rpx;
}

.store-card-footer {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.store-status-tag {
  width: 104rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #4a4f6c;
  color: #fff;
  font-size: 22rpx;
  font-weight: 900;
}

.store-actions {
  display: flex;
  gap: 14rpx;
}

.store-map-btn,
.store-enter-btn {
  min-width: 120rpx;
  height: 52rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 26rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.store-map-btn {
  border: 1rpx solid #e5e7eb;
  color: #111827;
  background: #fff;
}

.store-enter-btn {
  background: #d46259;
  color: #fff;
}
