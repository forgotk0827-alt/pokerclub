.home-page {
  padding-bottom: 250rpx;
  background:
    linear-gradient(180deg, rgba(39, 23, 62, 0.98) 0%, #120a1f 320rpx),
    #120a1f;
}

.notice {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  z-index: 2;
  height: 76rpx;
  display: flex;
  align-items: center;
  overflow: hidden;
  white-space: nowrap;
  color: #f5d0fe;
  background: rgba(18, 10, 31, 0.72);
  box-shadow: none;
  font-size: 28rpx;
  font-weight: 800;
}

.notice-track {
  flex: 0 0 auto;
  min-width: 100%;
  padding-left: 100%;
  animation: notice-marquee 15s linear infinite;
}

@keyframes notice-marquee {
  from {
    transform: translateX(0);
  }

  to {
    transform: translateX(-200%);
  }
}

.hero {
  position: relative;
  margin: 0 28rpx 32rpx;
  height: 620rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #180f27;
  box-shadow: 0 20rpx 46rpx rgba(24, 11, 39, 0.38);
}

.hero-img {
  width: 100%;
  height: 100%;
}

.hero-copy {
  position: absolute;
  left: 0;
  right: 0;
  top: 470rpx;
  text-align: center;
  text-shadow: 0 5rpx 12rpx rgba(0, 0, 0, 0.62);
}

.hero-title {
  color: #f5d389;
  font-size: 70rpx;
  font-weight: 900;
}

.hero-subtitle {
  margin-top: 8rpx;
  color: #fff;
  font-size: 34rpx;
  font-weight: 900;
}

.store {
  min-height: 140rpx;
  padding: 18rpx 20rpx;
  display: flex;
  align-items: center;
  background: #241633;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.store-thumb {
  flex: 0 0 106rpx;
  width: 106rpx;
  height: 106rpx;
  border-radius: 8rpx;
  background: #180f27;
}

.store-main {
  min-width: 0;
  flex: 1;
  padding-left: 18rpx;
}

.store-top {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.store-name {
  flex: 1;
  color: #fff;
  font-size: 27rpx;
  line-height: 34rpx;
  font-weight: 800;
}

.store-status {
  flex: 0 0 auto;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(139, 92, 246, 0.18);
  color: #d8b4fe;
  font-size: 25rpx;
  font-weight: 900;
}

.store-bottom {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 12rpx;
}

.store-address {
  flex: 1;
  color: #c6b8dc;
  font-size: 22rpx;
  line-height: 30rpx;
}

.link {
  color: #d8b4fe;
}

.store-side {
  flex: 0 0 66rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #9f9f9f;
  font-size: 20rpx;
  font-weight: 700;
}

.side-label,
.side-scan {
  line-height: 1.1;
}

.side-symbol {
  margin-right: 4rpx;
  color: #999;
  font-size: 24rpx;
}

.side-scan {
  color: #d8b4fe;
}

.store-arrow {
  width: 26rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9a9a9a;
  font-size: 62rpx;
  line-height: 1;
}

.nearest-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 90;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  box-sizing: border-box;
}

.nearest-dialog {
  width: 100%;
  padding: 36rpx 32rpx 30rpx;
  border-radius: 8rpx;
  background: #241633;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 26rpx 70rpx rgba(0, 0, 0, 0.45);
  box-sizing: border-box;
}

.nearest-title {
  color: #fff;
  text-align: center;
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.nearest-content {
  margin-top: 24rpx;
  color: #e9d5ff;
  text-align: center;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 700;
}

.nearest-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 34rpx;
}

.nearest-btn {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  padding: 0 12rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 84rpx;
}

.nearest-secondary {
  color: #d8b4fe;
  background: rgba(255, 255, 255, 0.08);
}

.nearest-primary {
  color: #fff;
  background: #8b5cf6;
}

.store-picker-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 80;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.58);
}

.store-picker-panel {
  width: 100%;
  max-height: 78vh;
  padding: 32rpx 28rpx calc(36rpx + env(safe-area-inset-bottom));
  border-radius: 8rpx 8rpx 0 0;
  background: #1b1028;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 -24rpx 60rpx rgba(0, 0, 0, 0.42);
  box-sizing: border-box;
}

.store-picker-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 22rpx;
}

.store-picker-title {
  color: #fff;
  font-size: 34rpx;
  line-height: 42rpx;
  font-weight: 900;
}

.store-picker-sub {
  margin-top: 6rpx;
  color: #bdaed2;
  font-size: 24rpx;
  line-height: 32rpx;
}

.store-picker-close {
  flex: 0 0 56rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #e9d5ff;
  font-size: 42rpx;
  line-height: 1;
}

.store-picker-list {
  max-height: 530rpx;
}

.store-picker-item {
  min-height: 132rpx;
  margin-bottom: 18rpx;
  padding: 22rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-radius: 8rpx;
  background: #241633;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-sizing: border-box;
}

.store-picker-active {
  border-color: rgba(216, 180, 254, 0.78);
  background: #2b1a3d;
}

.store-picker-main {
  min-width: 0;
  flex: 1;
}

.store-picker-name {
  color: #fff;
  font-size: 29rpx;
  line-height: 38rpx;
  font-weight: 900;
}

.store-picker-address {
  margin-top: 8rpx;
  color: #c6b8dc;
  font-size: 23rpx;
  line-height: 31rpx;
}

.store-picker-status {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  color: #d8b4fe;
  background: rgba(139, 92, 246, 0.16);
  font-size: 23rpx;
  font-weight: 900;
}

.store-picker-empty {
  padding: 60rpx 0;
  color: #bdaed2;
  text-align: center;
  font-size: 26rpx;
}

.store-picker-more {
  height: 86rpx;
  margin-top: 12rpx;
  border-radius: 8rpx;
  background: #8b5cf6;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
}

.quick {
  height: 140rpx;
  margin-top: 28rpx;
  display: flex;
  background: #241633;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.quick-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
}

.quick-item text {
  display: block;
  width: 100%;
  text-align: center;
}

.quick-icon {
  position: relative;
  width: 64rpx;
  height: 58rpx;
  color: #8b5cf6;
}

.food-knob {
  position: absolute;
  left: 26rpx;
  top: 0;
  width: 14rpx;
  height: 16rpx;
  border: 6rpx solid #8b5cf6;
  border-bottom: 0;
  border-radius: 14rpx 14rpx 0 0;
}

.food-dome {
  position: absolute;
  left: 7rpx;
  top: 17rpx;
  width: 50rpx;
  height: 40rpx;
  border-radius: 42rpx 42rpx 8rpx 8rpx;
  background: #8b5cf6;
}

.food-line {
  position: absolute;
  left: 2rpx;
  right: 2rpx;
  bottom: 0;
  height: 6rpx;
  border-radius: 6rpx;
  background: #8b5cf6;
}

.icon-ticket {
  width: 54rpx;
  height: 58rpx;
  padding: 18rpx 12rpx 0;
  border-radius: 6rpx;
  background: #8b5cf6;
}

.ticket-pin {
  position: absolute;
  top: -8rpx;
  width: 6rpx;
  height: 16rpx;
  border-radius: 6rpx;
  background: #8b5cf6;
}

.ticket-pin.left {
  left: 12rpx;
}

.ticket-pin.right {
  right: 12rpx;
}

.ticket-line {
  width: 28rpx;
  height: 5rpx;
  margin-bottom: 8rpx;
  border-radius: 5rpx;
  background: #fff;
  opacity: 0.95;
}

.ticket-line.short {
  width: 22rpx;
}

.icon-partner {
  width: 66rpx;
  height: 62rpx;
}

.partner-head {
  position: absolute;
  left: 18rpx;
  top: 0;
  width: 34rpx;
  height: 32rpx;
  border-radius: 14rpx 14rpx 18rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #8b5cf6;
}

.partner-eye {
  width: 5rpx;
  height: 10rpx;
  border-radius: 5rpx;
  background: #fff;
  opacity: 0.95;
}

.partner-body {
  position: absolute;
  left: 6rpx;
  bottom: 0;
  width: 56rpx;
  height: 34rpx;
  border-radius: 28rpx 28rpx 12rpx 12rpx;
  background: #8b5cf6;
}

.product-card {
  position: relative;
  min-height: 170rpx;
  padding: 22rpx 92rpx 22rpx 22rpx;
  display: flex;
  align-items: center;
  background: #241633;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.product-img {
  flex: 0 0 140rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  background: #180f27;
}

.product-info {
  min-width: 0;
  flex: 1;
  padding-left: 22rpx;
}

.product-name {
  color: #fff;
  font-size: 30rpx;
  line-height: 38rpx;
  font-weight: 900;
}

.product-desc {
  margin-top: 10rpx;
  color: #c6b8dc;
  font-size: 26rpx;
  line-height: 34rpx;
}

.product-price {
  margin-top: 16rpx;
  color: #d8b4fe;
  font-size: 36rpx;
  font-weight: 900;
}

.product-price text {
  font-size: 26rpx;
}

.add-btn {
  position: absolute;
  right: 18rpx;
  top: 50%;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #8b5cf6;
  transform: translateY(-50%);
}

.plus-line {
  position: absolute;
  border-radius: 2rpx;
  background: #151515;
}

.plus-h {
  width: 18rpx;
  height: 5rpx;
}

.plus-v {
  width: 5rpx;
  height: 18rpx;
}

.section-head {
  height: 104rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #fff;
}

.section-name {
  font-size: 34rpx;
  line-height: 42rpx;
  font-weight: 500;
}

.section-more {
  color: #c6b8dc;
  font-size: 28rpx;
  line-height: 36rpx;
}

.home-rank-panel {
  padding: 0 22rpx 24rpx;
}

.home-rank-tabs {
  margin-bottom: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.home-rank-tab {
  height: 58rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  color: #d8ccef;
  font-size: 25rpx;
  font-weight: 800;
}

.home-rank-tab.active {
  background: #8b5cf6;
  color: #fff;
}

.home-rank-card {
  min-height: 112rpx;
  margin-bottom: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 8rpx;
  display: grid;
  grid-template-columns: 78rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
  background: #241633;
  border: 1rpx solid rgba(216, 180, 254, 0.13);
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.2);
  box-sizing: border-box;
}

.home-rank-card.top-row {
  grid-template-columns: 88rpx minmax(0, 1fr) 96rpx;
  min-height: 132rpx;
  padding: 22rpx;
  border-width: 2rpx;
  box-shadow: 0 18rpx 42rpx rgba(24, 11, 39, 0.36);
}

.home-rank-card.top-one {
  background:
    linear-gradient(135deg, rgba(245, 158, 11, 0.28), rgba(124, 58, 237, 0.24)),
    #2c1746;
  border-color: rgba(251, 191, 36, 0.7);
}

.home-rank-card.top-two {
  background:
    linear-gradient(135deg, rgba(203, 213, 225, 0.2), rgba(139, 92, 246, 0.22)),
    #25183a;
  border-color: rgba(226, 232, 240, 0.48);
}

.home-rank-card.top-three {
  background:
    linear-gradient(135deg, rgba(217, 119, 6, 0.22), rgba(139, 92, 246, 0.2)),
    #241633;
  border-color: rgba(251, 146, 60, 0.48);
}

.home-rank-badge {
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #8b5cf6;
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
}

.home-rank-main {
  min-width: 0;
}

.home-rank-name {
  color: #fff;
  font-size: 30rpx;
  line-height: 40rpx;
  font-weight: 900;
  word-break: break-all;
}

.home-rank-score {
  margin-top: 8rpx;
  color: #f0c15a;
  font-size: 26rpx;
  font-weight: 900;
}

.home-rank-medal {
  height: 46rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 23rpx;
  font-weight: 900;
  white-space: nowrap;
}

.top-one .home-rank-badge {
  width: 78rpx;
  height: 78rpx;
  background: #f59e0b;
  box-shadow: 0 0 0 8rpx rgba(245, 158, 11, 0.16);
  color: #2b1603;
}

.top-two .home-rank-badge {
  width: 72rpx;
  height: 72rpx;
  background: #cbd5e1;
  color: #1e1b4b;
}

.top-three .home-rank-badge {
  width: 72rpx;
  height: 72rpx;
  background: #fb923c;
  color: #2b1603;
}

.top-one .home-rank-name {
  color: #fff7ed;
  font-size: 34rpx;
}

.top-two .home-rank-name,
.top-three .home-rank-name {
  color: #f8f2ff;
  font-size: 32rpx;
}

.top-one .home-rank-score {
  color: #fbbf24;
  font-size: 29rpx;
}

.top-two .home-rank-score {
  color: #e2e8f0;
}

.top-three .home-rank-score {
  color: #fed7aa;
}

.top-one .home-rank-medal {
  background: #f59e0b;
  color: #2b1603;
}

.top-two .home-rank-medal {
  background: #cbd5e1;
  color: #1e1b4b;
}

.top-three .home-rank-medal {
  background: #fb923c;
  color: #2b1603;
}

.home-rank-empty {
  padding: 28rpx 0 8rpx;
  color: #8f86a1;
  font-size: 24rpx;
  line-height: 32rpx;
  text-align: center;
}

.home-activity-list {
  padding: 0 22rpx 24rpx;
}

.home-activity-card {
  position: relative;
  margin-bottom: 22rpx;
  padding: 28rpx 22rpx 24rpx;
  border-radius: 18rpx;
  background: #241633;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.home-activity-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.home-activity-title {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #fff;
  font-size: 31rpx;
  line-height: 40rpx;
  font-weight: 900;
}

.home-activity-link {
  flex: 0 0 auto;
  color: #d8b4fe;
  font-size: 27rpx;
  line-height: 36rpx;
  font-weight: 800;
}

.home-activity-body {
  position: relative;
  margin-top: 26rpx;
  display: grid;
  grid-template-columns: 164rpx minmax(0, 1fr) 118rpx;
  gap: 18rpx;
  align-items: start;
}

.home-activity-img {
  width: 164rpx;
  height: 164rpx;
  border-radius: 6rpx;
  background: #180f27;
}

.home-activity-main {
  min-width: 0;
}

.home-meta-line {
  height: 50rpx;
  display: flex;
  align-items: center;
  color: #fff;
  font-size: 27rpx;
  line-height: 34rpx;
  font-weight: 800;
}

.home-meta-icon {
  flex: 0 0 44rpx;
  width: 44rpx;
  height: 40rpx;
  margin-right: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f4f5f6;
  color: #242526;
  font-size: 26rpx;
}

.home-activity-price {
  color: #d8b4fe;
  text-align: right;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 700;
}

.home-join-row {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.home-avatars {
  display: flex;
  gap: 14rpx;
}

.home-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #6788aa;
  color: #e8e8e8;
  font-size: 20rpx;
}

.home-quota {
  color: #fff;
  font-size: 25rpx;
}

.home-quota text {
  color: #d8b4fe;
  font-weight: 900;
}
