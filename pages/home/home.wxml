<topbar title="首页" />
<scroll-view scroll-y class="page home-page">
  <view class="hero">
    <image class="hero-img" src="/bac-clean.jpg" mode="aspectFit" />
    <view class="notice">
      <view class="notice-track">{{globalSettings.homeNotice || '破壳派酒吧欢迎您'}}</view>
    </view>
  </view>

  <view class="store card">
    <image class="store-thumb" src="/bac-clean.jpg" mode="aspectFill" />
    <view class="store-main">
      <view class="store-top">
        <text class="store-name">{{store.name}}</text>
        <text class="store-status">{{store.status}}</text>
      </view>
      <view class="store-bottom">
        <view class="store-address">
          {{store.address}}
          <text class="link" bindtap="openNavigation">[导航]</text>
        </view>
        <view class="store-side">
          <view class="side-label"><text class="side-symbol">◎</text>位置</view>
          <view class="side-scan" bindtap="switchStore">切换</view>
        </view>
      </view>
    </view>
    <view class="store-arrow" bindtap="switchStore">›</view>
  </view>

  <view class="quick card">
    <button class="quick-item" bindtap="scanOrder">
      <view class="quick-icon icon-food">
        <view class="food-knob"></view>
        <view class="food-dome"></view>
        <view class="food-line"></view>
      </view>
      <text>扫码点餐</text>
    </button>
    <button class="quick-item" bindtap="goActivity">
      <view class="quick-icon icon-ticket">
        <view class="ticket-pin left"></view>
        <view class="ticket-pin right"></view>
        <view class="ticket-line"></view>
        <view class="ticket-line short"></view>
        <view class="ticket-line"></view>
      </view>
      <text>活动报名</text>
    </button>
    <button class="quick-item" bindtap="goLeaderboard">
      <view class="quick-icon icon-ticket">
        <view class="ticket-pin left"></view>
        <view class="ticket-pin right"></view>
        <view class="ticket-line"></view>
        <view class="ticket-line short"></view>
        <view class="ticket-line"></view>
      </view>
      <text>排行榜</text>
    </button>
    <button class="quick-item" bindtap="goVideos">
      <view class="quick-icon icon-partner">
        <view class="partner-head">
          <view class="partner-eye"></view>
          <view class="partner-eye"></view>
        </view>
        <view class="partner-body"></view>
      </view>
      <text>精彩呈现</text>
    </button>
    <button class="quick-item" bindtap="goRecharge">
      <view class="quick-icon icon-ticket">
        <view class="ticket-pin left"></view>
        <view class="ticket-pin right"></view>
        <view class="ticket-line"></view>
        <view class="ticket-line short"></view>
        <view class="ticket-line"></view>
      </view>
      <text>我的背包</text>
    </button>
  </view>

  <view class="section-title">桌游套餐</view>
  <view class="product-list">
    <view class="product-card card" wx:for="{{featured}}" wx:key="id">
      <image class="product-img" src="{{item.image}}" mode="aspectFill" />
      <view class="product-info">
        <view class="product-name">{{item.name}}</view>
        <view class="product-desc">{{item.desc}}</view>
        <view class="product-price">¥{{item.price}}.00/<text>{{item.unit}}</text></view>
      </view>
      <view class="add-btn" data-id="{{item.id}}" bindtap="addCart">
        <view class="plus-line plus-h"></view>
        <view class="plus-line plus-v"></view>
      </view>
    </view>
  </view>

  <view class="section-head">
    <view class="section-name">排行榜</view>
    <view class="section-more" bindtap="goLeaderboard">更多</view>
  </view>
  <view class="home-rank-panel">
    <view class="home-rank-tabs">
      <view
        class="home-rank-tab {{activeRankType === item.key ? 'active' : ''}}"
        wx:for="{{leaderboardTabs}}"
        wx:key="key"
        data-type="{{item.key}}"
        bindtap="switchRankType"
      >{{item.label}}</view>
    </view>
    <view class="home-rank-card {{index == 0 ? 'top-row top-one' : ''}} {{index == 1 ? 'top-row top-two' : ''}} {{index == 2 ? 'top-row top-three' : ''}}" wx:for="{{leaderboardList}}" wx:for-item="item" wx:for-index="index" wx:key="id" bindtap="goLeaderboard">
      <view class="home-rank-badge">{{item.rank}}</view>
      <view class="home-rank-main">
        <view class="home-rank-name">{{item.username}}</view>
        <view class="home-rank-score">{{item.score}} 分</view>
      </view>
      <view wx:if="{{index < 3}}" class="home-rank-medal">{{index == 0 ? '冠军' : index == 1 ? '亚军' : '季军'}}</view>
    </view>
    <view wx:if="{{!leaderboardList.length}}" class="home-rank-empty">暂无数据</view>
  </view>
</scroll-view>
<cart-summary-bar summary="{{cartSummary}}" bind:cartchange="handleCartChange" />
<main-tabbar active="home" />
