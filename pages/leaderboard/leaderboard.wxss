.rank-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 60rpx;
  background:
    linear-gradient(180deg, #172325 0%, #0b0f10 360rpx),
    #0b0f10;
  color: #fff;
}

.rank-hero {
  min-height: 160rpx;
  padding: 32rpx 28rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #233437, #151b1d);
  border: 1rpx solid rgba(240, 193, 90, 0.18);
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.28);
}

.hero-title {
  font-size: 42rpx;
  line-height: 54rpx;
  font-weight: 900;
  color: #f7f0df;
}

.hero-sub {
  margin-top: 10rpx;
  color: #b7c0c3;
  font-size: 25rpx;
}

.rank-tabs {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.rank-tab {
  height: 58rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  color: #d8ccef;
  font-size: 25rpx;
  font-weight: 800;
}

.rank-tab.active {
  background: #8b5cf6;
  color: #fff;
}

.rank-list {
  margin-top: 24rpx;
}

.rank-row {
  min-height: 112rpx;
  margin-bottom: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 8rpx;
  display: grid;
  grid-template-columns: 78rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
  background: #1b2022;
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.2);
}

.top-row {
  grid-template-columns: 88rpx minmax(0, 1fr) 96rpx;
  min-height: 132rpx;
  padding: 22rpx 22rpx;
  border-width: 2rpx;
  transform: translateY(0);
}

.rank-num {
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #d74f45;
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
}

.rank-main {
  min-width: 0;
}

.rank-name {
  color: #fff;
  font-size: 30rpx;
  line-height: 40rpx;
  font-weight: 900;
  word-break: break-all;
}

.rank-score {
  margin-top: 8rpx;
  color: #f0c15a;
  font-size: 26rpx;
  font-weight: 900;
}

.rank-medal {
  height: 46rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 23rpx;
  font-weight: 900;
  white-space: nowrap;
}

.rank-page {
  background:
    linear-gradient(180deg, #2d1b46 0%, #120a1f 360rpx),
    #120a1f;
}

.rank-hero {
  background: linear-gradient(135deg, #3b1b5f, #1b102b);
  border-color: rgba(216, 180, 254, 0.2);
  box-shadow: 0 18rpx 42rpx rgba(24, 11, 39, 0.34);
}

.hero-title {
  color: #f4ecff;
}

.hero-sub {
  color: #c6b8dc;
}

.rank-row {
  background: #241633;
  border-color: rgba(216, 180, 254, 0.13);
}

.top-row {
  box-shadow: 0 18rpx 42rpx rgba(24, 11, 39, 0.36);
}

.rank-num {
  background: #8b5cf6;
}

.rank-score {
  color: #d8b4fe;
}

.top-one {
  background:
    linear-gradient(135deg, rgba(245, 158, 11, 0.28), rgba(124, 58, 237, 0.24)),
    #2c1746;
  border-color: rgba(251, 191, 36, 0.7);
}

.top-two {
  background:
    linear-gradient(135deg, rgba(203, 213, 225, 0.2), rgba(139, 92, 246, 0.22)),
    #25183a;
  border-color: rgba(226, 232, 240, 0.48);
}

.top-three {
  background:
    linear-gradient(135deg, rgba(217, 119, 6, 0.22), rgba(139, 92, 246, 0.2)),
    #241633;
  border-color: rgba(251, 146, 60, 0.48);
}

.top-one .rank-num {
  width: 78rpx;
  height: 78rpx;
  background: #f59e0b;
  box-shadow: 0 0 0 8rpx rgba(245, 158, 11, 0.16);
  color: #2b1603;
}

.top-two .rank-num {
  width: 72rpx;
  height: 72rpx;
  background: #cbd5e1;
  color: #1e1b4b;
}

.top-three .rank-num {
  width: 72rpx;
  height: 72rpx;
  background: #fb923c;
  color: #2b1603;
}

.top-one .rank-name {
  color: #fff7ed;
  font-size: 34rpx;
}

.top-two .rank-name,
.top-three .rank-name {
  color: #f8f2ff;
  font-size: 32rpx;
}

.top-one .rank-score {
  color: #fbbf24;
  font-size: 29rpx;
}

.top-two .rank-score {
  color: #e2e8f0;
}

.top-three .rank-score {
  color: #fed7aa;
}

.top-one .rank-medal {
  background: #f59e0b;
  color: #2b1603;
}

.top-two .rank-medal {
  background: #cbd5e1;
  color: #1e1b4b;
}

.top-three .rank-medal {
  background: #fb923c;
  color: #2b1603;
}
