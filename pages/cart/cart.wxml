<topbar title="购物车" />
<view class="page cart-page">
  <view class="cart-head">
    <text class="cart-count">已点{{summary.count}}份</text>
    <button class="clear-btn" bindtap="clearCart">清空</button>
  </view>
  <view class="table-info" wx:if="{{tableContext}}">
    <text>{{store.shortName || store.name}}</text>
    <text>{{tableContext.tableName}}</text>
  </view>

  <scroll-view scroll-y class="cart-list">
    <view wx:if="{{cart.length}}">
      <view class="cart-item" wx:for="{{cart}}" wx:key="cartKey">
        <image class="cart-img" src="{{item.image}}" mode="aspectFill" />
        <view class="cart-info">
          <view class="cart-name">{{item.name}}</view>
          <view class="cart-desc">{{item.desc}}</view>
          <view class="cart-meta">
            <text class="cart-price" wx:if="{{item.payType === 'points'}}">{{item.points || 0}}积分</text>
            <text class="cart-price" wx:else>¥{{item.price}}.00</text>
            <text class="cart-unit">x{{item.count}}</text>
          </view>
          <view class="pay-switch" wx:if="{{item.points}}">
            <view class="pay-option {{item.payType !== 'points' ? 'pay-option-active' : ''}}" data-id="{{item.cartKey || item.id}}" data-pay-type="cash" bindtap="switchPayType">现金</view>
            <view class="pay-option {{item.payType === 'points' ? 'pay-option-active' : ''}}" data-id="{{item.cartKey || item.id}}" data-pay-type="points" bindtap="switchPayType">{{item.points}}积分</view>
          </view>
        </view>
        <view class="stepper">
          <view class="step-btn" data-id="{{item.cartKey || item.id}}" data-delta="-1" bindtap="changeCount">-</view>
          <text class="step-num">{{item.count}}</text>
          <view class="step-btn" data-id="{{item.cartKey || item.id}}" data-delta="1" bindtap="changeCount">+</view>
        </view>
      </view>
    </view>
    <view wx:else class="empty-state">
      <text class="empty-text">暂无商品数据</text>
    </view>
  </scroll-view>

  <view class="checkout-bar">
    <view class="pay-info">
      <text>现金预估:</text>
      <text class="pay-amount">¥{{summary.total}}元</text>
    </view>
    <view wx:if="{{summary.voucherDiscount}}" class="pay-sub">酒水券抵扣 ¥{{summary.voucherDiscount}}</view>
    <view wx:if="{{summary.pointsUsed}}" class="pay-sub">积分支付 {{summary.pointsUsed}} 积分</view>
    <button class="checkout-btn" bindtap="checkout">去结算</button>
  </view>
</view>
<main-tabbar active="cart" />
