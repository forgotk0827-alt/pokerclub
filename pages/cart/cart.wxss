.cart-page {
  padding-bottom: 150rpx;
}

.cart-head {
  height: 78rpx;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #efefef;
  color: #666;
}

.cart-count {
  font-size: 30rpx;
  font-weight: 700;
}

.clear-btn {
  color: #666;
  font-size: 28rpx;
}

.table-info {
  height: 58rpx;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #151515;
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
}

.cart-list {
  height: calc(100vh - 416rpx);
  background: #050807;
}

.cart-item {
  margin: 20rpx 22rpx 0;
  padding: 22rpx;
  display: grid;
  grid-template-columns: 128rpx minmax(0, 1fr) 142rpx;
  gap: 18rpx;
  align-items: center;
  border-radius: 8rpx;
  background: #242526;
}

.cart-img {
  display: block;
  width: 128rpx;
  height: 128rpx;
  min-width: 128rpx;
  background: #111;
}

.cart-info {
  min-width: 0;
}

.cart-name {
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  color: #fff;
  font-size: 28rpx;
  line-height: 36rpx;
  font-weight: 900;
}

.cart-desc {
  margin-top: 8rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  color: #a2a2a2;
  font-size: 24rpx;
  line-height: 32rpx;
}

.cart-meta {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.cart-price {
  color: #ef5b58;
  font-size: 30rpx;
  font-weight: 900;
}

.cart-unit {
  color: #bababa;
  font-size: 24rpx;
}

.pay-switch {
  margin-top: 14rpx;
  display: flex;
  width: 240rpx;
  height: 52rpx;
  padding: 4rpx;
  border-radius: 8rpx;
  background: #171717;
  border: 1rpx solid rgba(239, 91, 88, 0.22);
}

.pay-option {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
  color: #bdbdbd;
  font-size: 22rpx;
  font-weight: 800;
}

.pay-option-active {
  background: #ef5b58;
  color: #151515;
}

.stepper {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
}

.step-btn {
  flex: 0 0 46rpx;
  width: 46rpx;
  height: 46rpx;
  min-width: 0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ef5b58;
  color: #111;
  font-size: 34rpx;
  font-weight: 900;
}

.step-num {
  flex: 0 0 36rpx;
  width: 36rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 800;
}

.empty-state {
  padding-top: 220rpx;
  text-align: center;
}

.empty-text {
  color: #fff;
  font-size: 34rpx;
  font-weight: 900;
}

.checkout-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 124rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  background: #242526;
}

.pay-info {
  flex: 1;
  padding-left: 44rpx;
  color: #fff;
  font-size: 31rpx;
  font-weight: 900;
}

.pay-sub {
  margin-right: 18rpx;
  color: #d8b4fe;
  font-size: 22rpx;
  font-weight: 700;
}

.pay-amount {
  color: #ef5b58;
  margin-left: 10rpx;
}

.checkout-btn {
  width: 248rpx;
  height: 104rpx;
  background: #e45855;
  color: #fff;
  font-size: 32rpx;
  font-weight: 900;
}

.cart-page,
.cart-list {
  background: #0b0f10;
}

.cart-head {
  background: #111719;
  color: #b7c0c3;
}

.table-info {
  background: #1b2022;
  color: #f7f0df;
}

.cart-item {
  background: #1b2022;
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.24);
}

.cart-img {
  border-radius: 8rpx;
  background: #101415;
}

.cart-desc,
.cart-unit {
  color: #aab3b6;
}

.cart-price,
.pay-amount {
  color: #f0c15a;
}

.step-btn,
.checkout-btn {
  background: #d74f45;
}

.checkout-bar {
  background: #1b2022;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.cart-page,
.cart-list {
  background: #120a1f;
}

.cart-head {
  background: #1b102b;
  color: #c6b8dc;
}

.table-info,
.checkout-bar {
  background: #241633;
  color: #f4ecff;
}

.cart-item {
  background: #241633;
  border-color: rgba(216, 180, 254, 0.13);
  box-shadow: 0 12rpx 30rpx rgba(24, 11, 39, 0.32);
}

.cart-img {
  background: #180f27;
}

.cart-desc,
.cart-unit {
  color: #c6b8dc;
}

.cart-price,
.pay-amount {
  color: #d8b4fe;
}

.step-btn,
.checkout-btn {
  background: #8b5cf6;
}
