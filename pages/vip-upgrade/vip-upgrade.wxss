.vip-page {
  min-height: 100vh;
  padding-bottom: 96rpx;
  background: #f7f7f7;
  color: #111827;
}

.vip-head {
  height: 132rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #242526;
}

.level-pill {
  height: 42rpx;
  padding: 0 12rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  background: linear-gradient(90deg, #ffdd3d, #ffae28);
  color: #fff;
  font-size: 26rpx;
  font-weight: 900;
}

.order-link {
  color: #ffd51d;
  font-size: 24rpx;
  font-weight: 800;
}

.select-head {
  height: 110rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
}

.select-title {
  color: #111827;
  font-size: 30rpx;
}

.select-tip {
  color: #6b7280;
  font-size: 22rpx;
}

.card-list {
  padding: 0 16rpx 30rpx;
  background: #fff;
}

.vip-card {
  height: 126rpx;
  margin-bottom: 24rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #222;
  box-shadow: 0 14rpx 26rpx rgba(0, 0, 0, 0.16);
  color: #fff;
}

.vip-card-active {
  border: 5rpx solid #4329ff;
  background: #2a2611;
  color: #ffd51d;
}

.card-title {
  min-width: 0;
  flex: 1;
  font-size: 29rpx;
  line-height: 38rpx;
  font-weight: 900;
}

.crown {
  flex: 0 0 96rpx;
  text-align: center;
}

.crown-top {
  height: 46rpx;
  color: #f6d77c;
  font-size: 24rpx;
  line-height: 46rpx;
  text-shadow: 0 2rpx 3rpx rgba(0, 0, 0, 0.35);
}

.card-price {
  color: #fff;
  font-size: 32rpx;
  line-height: 38rpx;
  font-weight: 900;
}

.vip-card:not(.vip-card-active) .card-price {
  color: #ffd51d;
}

.pay-section {
  margin-top: 24rpx;
  background: #fff;
}

.pay-title {
  height: 90rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  font-size: 30rpx;
}

.pay-row {
  height: 84rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  color: #374151;
  font-size: 26rpx;
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #66b979;
  color: #fff;
  font-size: 18rpx;
}

.check {
  margin-left: auto;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #d7655b;
  color: #fff;
  font-size: 22rpx;
}

.bottom-pay {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 82rpx;
  display: grid;
  grid-template-columns: 1fr 210rpx;
  background: #fff;
}

.bottom-price {
  padding-left: 24rpx;
  display: flex;
  align-items: center;
  color: #d7655b;
  font-size: 32rpx;
  font-weight: 900;
}

.open-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #d7655b;
  color: #fff;
  font-size: 29rpx;
  font-weight: 800;
}
