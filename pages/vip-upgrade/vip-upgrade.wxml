<topbar title="会员升级" showBack="{{true}}" />
<view class="vip-page">
  <view class="vip-head">
    <view class="level-pill">当前等级：{{member.level}}</view>
    <view class="order-link" bindtap="goVipOrders">VIP订单记录</view>
  </view>

  <view class="select-head">
    <text class="select-title">选择会员等级</text>
    <text class="select-tip">开通后立即生效，到期不自动续费</text>
  </view>

  <view class="card-list">
    <view wx:for="{{cards}}" wx:key="id" class="vip-card {{selected === item.id ? 'vip-card-active' : ''}}" data-id="{{item.id}}" bindtap="selectCard">
      <view class="card-title">{{item.name}}(每日可取{{item.points}}积分)</view>
      <view class="crown">
        <view class="crown-top">VIP</view>
        <view class="card-price">¥{{item.price}}</view>
      </view>
    </view>
  </view>

  <view class="pay-section">
    <view class="pay-title">支付方式</view>
    <view class="pay-row">
      <view class="wechat-icon">微</view>
      <text>微信支付</text>
      <view class="check">✓</view>
    </view>
  </view>

  <view class="bottom-pay">
    <view class="bottom-price">¥{{selectedCard.price}}</view>
    <view class="open-btn" bindtap="openVip">立即开通</view>
  </view>
</view>
