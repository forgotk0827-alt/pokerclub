.recharge-page {
  min-height: calc(100vh - 76px);
  padding: 26rpx 28rpx 150rpx;
  background: #f6f6f6;
  color: #101010;
}

.balance-card {
  min-height: 286rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #d46259;
  color: #fff;
}

.balance-label {
  font-size: 30rpx;
  font-weight: 800;
}

.balance-num {
  margin-top: 36rpx;
  font-size: 66rpx;
  line-height: 72rpx;
  font-weight: 900;
}

.balance-tip {
  margin-top: 46rpx;
  font-size: 27rpx;
  font-weight: 700;
}

.section {
  margin: 26rpx -28rpx 0;
  padding: 34rpx 28rpx;
  background: #fff;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  color: #111;
  font-size: 32rpx;
  line-height: 42rpx;
  font-weight: 900;
}

.section-sub {
  min-width: 0;
  color: #576071;
  font-size: 25rpx;
  line-height: 34rpx;
  text-align: right;
}

.package-row {
  margin-top: 34rpx;
  white-space: nowrap;
}

.package-card {
  position: relative;
  width: 204rpx;
  min-height: 122rpx;
  margin-right: 26rpx;
  padding: 20rpx 16rpx;
  border: 1rpx solid transparent;
  border-radius: 16rpx;
  display: inline-flex;
  vertical-align: top;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #eeeeee;
  white-space: normal;
}

.package-active {
  border-color: #d46259;
  background: #fff;
}

.package-tip {
  color: #20242b;
  font-size: 25rpx;
  line-height: 34rpx;
  text-align: center;
}

.package-pay {
  color: #d46259;
  font-size: 34rpx;
  line-height: 42rpx;
  font-weight: 900;
}

.package-credit {
  margin-top: 4rpx;
  color: #5d6570;
  font-size: 29rpx;
  line-height: 36rpx;
  font-weight: 700;
}

.pay-row {
  margin-top: 26rpx;
}

.pay-item {
  height: 82rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.pay-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #7dbb67;
  color: #fff;
  font-size: 20rpx;
  font-weight: 900;
}

.pay-name {
  flex: 1;
  color: #59606a;
  font-size: 30rpx;
  font-weight: 800;
}

.pay-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #d46259;
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
}

.history {
  padding-bottom: 28rpx;
}

.empty {
  margin-top: 26rpx;
  color: #98a1ad;
  font-size: 26rpx;
  text-align: center;
}

.record-row {
  min-height: 82rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.record-main {
  min-width: 0;
}

.record-name {
  color: #111;
  font-size: 27rpx;
  font-weight: 900;
}

.record-sub {
  margin-top: 6rpx;
  color: #8d95a1;
  font-size: 22rpx;
}

.record-amount {
  color: #d46259;
  font-size: 30rpx;
  font-weight: 900;
}

.recharge-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 116rpx;
  display: grid;
  grid-template-columns: 1fr 180rpx 250rpx;
  align-items: center;
  background: #fff;
  box-shadow: 0 -8rpx 22rpx rgba(0, 0, 0, 0.08);
}

.recharge-price {
  padding-left: 28rpx;
  color: #d46259;
  font-size: 34rpx;
  font-weight: 900;
}

.recharge-after {
  color: #6f7780;
  font-size: 22rpx;
  line-height: 30rpx;
  text-align: right;
}

.recharge-btn {
  width: 250rpx;
  height: 116rpx;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #d46259;
  color: #fff;
  font-size: 32rpx;
  font-weight: 900;
}
