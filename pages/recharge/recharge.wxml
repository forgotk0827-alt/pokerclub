<topbar title="储值账户" showBack="{{true}}" />
<view class="page recharge-page">
  <view class="balance-card">
    <view class="balance-label">可用余额</view>
    <view class="balance-num">{{member.balance}}</view>
    <view class="balance-tip">{{settings.note}}</view>
    <view class="balance-extra">我的酒水券：{{member.drinkVoucherCount || 0}}</view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">选择套餐</view>
      <view class="section-sub">{{settings.title}}</view>
    </view>
    <scroll-view scroll-x class="package-row" enable-flex>
      <view wx:for="{{settings.packages}}" wx:key="id" class="package-card {{!useCustomRecharge && selectedIndex === index ? 'package-active' : ''}}" data-index="{{index}}" bindtap="selectPackage">
        <view class="package-pay">{{item.label}}</view>
        <view wx:if="{{item.subLabel || item.voucherCount}}" class="package-sub">{{item.subLabel || ('赠送' + item.voucherCount + '张酒水券')}}</view>
      </view>
    </scroll-view>
  </view>

  <view class="section custom-section {{useCustomRecharge ? 'custom-active' : ''}}" bindtap="selectCustomRecharge">
    <view class="section-head">
      <view class="section-title">自定义充值</view>
    </view>
    <view class="custom-amount-row">
      <view class="custom-currency">¥</view>
      <input value="{{customPayAmount}}" type="number" placeholder="输入充值金额" bindinput="inputCustomPayAmount" />
    </view>
  </view>

  <view class="recharge-bar">
    <view class="recharge-price">¥{{selectedRechargeAmount}}</view>
    <button class="recharge-btn" bindtap="rechargeNow">立即充值</button>
  </view>
</view>
