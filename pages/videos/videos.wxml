<topbar title="精彩呈现" showBack="{{true}}" />
<scroll-view scroll-y class="showcase-page">
  <view class="showcase-copy" wx:if="{{globalSettings.showcaseText}}">{{globalSettings.showcaseText}}</view>
  <view class="showcase-card" wx:if="{{images.length}}">
    <swiper class="showcase-swiper" indicator-dots autoplay circular interval="3600" duration="450" indicator-color="rgba(255,255,255,0.34)" indicator-active-color="#ffffff">
      <swiper-item wx:for="{{images}}" wx:key="*this">
        <image class="showcase-image" src="{{item}}" mode="aspectFill" />
      </swiper-item>
    </swiper>
  </view>
  <view wx:else class="showcase-empty">暂无展示图片</view>
</scroll-view>
