page {
  min-height: 100%;
  background: #0b0f10;
  color: #fff;
  font-family: "瘦金体", "FZShouJinShu-S10S", "FZShouJinShu", "STSong", serif;
  font-size: 28rpx;
}

view,
text,
scroll-view,
button,
input,
textarea,
picker,
navigator {
  box-sizing: border-box;
  font-family: "瘦金体", "FZShouJinShu-S10S", "FZShouJinShu", "STSong", serif;
}

button {
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  line-height: 1;
  color: inherit;
  font: inherit;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding-bottom: 150rpx;
  background:
    linear-gradient(180deg, rgba(25, 33, 34, 0.96) 0%, #0b0f10 280rpx),
    #0b0f10;
}

.section-title {
  padding: 34rpx 28rpx 20rpx;
  color: #f7f0df;
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.card {
  margin: 0 28rpx 24rpx;
  border-radius: 8rpx;
  background: #1b2022;
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.28);
  overflow: hidden;
}

.muted {
  color: #aab3b6;
}

.price {
  color: #f0c15a;
  font-weight: 900;
}

.accent {
  color: #f0c15a;
}

.primary-btn {
  min-height: 74rpx;
  padding: 0 34rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #d74f45;
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
}

.ghost-btn {
  min-height: 64rpx;
  padding: 0 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.26);
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
}

image {
  will-change: transform;
}

.line-clamp {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

page {
  background: #120a1f;
  color: #f4ecff;
}

.page {
  background:
    linear-gradient(180deg, rgba(39, 23, 62, 0.96) 0%, #120a1f 300rpx),
    #120a1f;
}

.section-title {
  color: #f4ecff;
}

.card {
  background: #241633;
  box-shadow: 0 14rpx 34rpx rgba(24, 11, 39, 0.36);
}

.muted {
  color: #c6b8dc;
}

.price,
.accent {
  color: #d8b4fe;
}

.primary-btn {
  background: #8b5cf6;
}
